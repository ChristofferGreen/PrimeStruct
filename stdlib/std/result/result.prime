namespace std {
  namespace result {
  [public sum]
  Result<E> {
    ok
    [E] error
  }

  [public sum]
  Result<T, E> {
    [T] ok
    [E] error
  }

  [public return<Result<E>>]
  ok<E>() {
    [Result<E>] result{}
    return(result)
  }

  [public return<Result<T, E>>]
  ok<T, E>([T] value) {
    [Result<T, E>] result{[ok] value}
    return(result)
  }

  [public return<Result<T, E>>]
  error<T, E>([E] err) {
    [Result<T, E>] result{[error] err}
    return(result)
  }
  }
}
