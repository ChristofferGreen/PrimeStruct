namespace std {
  namespace result {
  [public sum]
  Result<E> {
    ok
    [E] error
  }

  [public sum]
  Result<T, E> {
    [T] ok
    [E] error
  }

  [public return<Result<E>>]
  ok<E>() {
    return(Result<E>{})
  }

  [public return<Result<T, E>>]
  ok<T, E>([T] value) {
    return(Result<T, E>{[ok] value})
  }

  [public return<Result<T, E>>]
  error<T, E>([E] err) {
    return(Result<T, E>{[error] err})
  }
  }
}
