// Internal conversion module behind canonical /std/collections/soa_vector_conversions/*.
// Direct imports remain only for targeted compatibility or conformance coverage.
import /std/collections/*
import /std/collections/experimental_soa_vector/*

namespace std {
  namespace collections {
  namespace experimental_soa_vector_conversions {
  [public effects(heap_alloc), return<vector<T>>]
  soaVectorToAos<T>([/std/collections/experimental_soa_vector/SoaVector<T>] values) {
    [i32] valueCount{/std/collections/experimental_soa_vector/soaVectorCount<T>(values)}
    [vector<T> mut] out{vector<T>()}
    [i32 mut] index{0i32}
    while(less_than(index, valueCount), do() {
      /std/collections/vector/push<T>(
          out, /std/collections/experimental_soa_vector/soaVectorGet<T>(values, index))
      increment(index)
    })
    return(out)
  }

  [public effects(heap_alloc), return<vector<T>>]
  soaVectorToAosRef<T>([Reference</std/collections/experimental_soa_vector/SoaVector<T>>] values) {
    [i32] valueCount{/std/collections/soa_vector/count_ref<T>(values)}
    [vector<T> mut] out{vector<T>()}
    [i32 mut] index{0i32}
    while(less_than(index, valueCount), do() {
      /std/collections/vector/push<T>(
          out, /std/collections/soa_vector/get_ref<T>(values, index))
      increment(index)
    })
    return(out)
  }

  [public effects(heap_alloc), return<vector<T>>]
  /std/collections/experimental_soa_vector/SoaVector/to_aos<T>(
      [/std/collections/experimental_soa_vector/SoaVector<T>] self) {
    return(soaVectorToAos<T>(self))
  }

  }
  }
}
