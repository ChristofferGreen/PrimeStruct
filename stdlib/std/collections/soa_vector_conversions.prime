import /std/collections/*
import /std/collections/experimental_soa_vector/*
import /std/collections/experimental_soa_vector_conversions/*

[public effects(heap_alloc), return<vector<T>>]
/std/collections/soa_vector/to_aos<T>([soa_vector<T>] values) {
  [i32] valueCount{/std/collections/soa_vector/count<T>(values)}
  [vector<T> mut] out{vector<T>()}
  [i32 mut] index{0i32}
  while(less_than(index, valueCount), do() {
    /std/collections/vector/push<T>(
        out, /std/collections/soa_vector/get<T>(values, index))
    increment(index)
  })
  return(out)
}

[public effects(heap_alloc), return<vector<T>>]
/std/collections/soa_vector/to_aos_ref<T>([Reference<soa_vector<T>>] values) {
  return(/std/collections/soa_vector/to_aos<T>(dereference(values)))
}
