// Canonical conversion wrappers for public soa_vector helpers.
import /std/collections/*
import /std/collections/experimental_soa_vector/*

[public effects(heap_alloc), return<vector<T>>]
/std/collections/soa_vector_conversions/soaVectorToAos<T>(
    [/std/collections/experimental_soa_vector/SoaVector<T>] values) {
  valueCount{/std/collections/soa_vector/count<T>(values)}
  [vector<T> mut] out{vector<T>()}
  [mut] index{0i32}
  while(less_than(index, valueCount), do() {
    /std/collections/vector/push<T>(
        out, /std/collections/soa_vector/get<T>(values, index))
    increment(index)
  })
  return(out)
}

[public effects(heap_alloc), return<vector<T>>]
/std/collections/soa_vector_conversions/soaVectorToAosRef<T>(
    [Reference</std/collections/experimental_soa_vector/SoaVector<T>>] values) {
  valueCount{/std/collections/soa_vector/count_ref<T>(values)}
  [vector<T> mut] out{vector<T>()}
  [mut] index{0i32}
  while(less_than(index, valueCount), do() {
    /std/collections/vector/push<T>(
        out, /std/collections/soa_vector/get_ref<T>(values, index))
    increment(index)
  })
  return(out)
}

[public effects(heap_alloc), return<vector<T>>]
/std/collections/soa_vector/to_aos<T>([/std/collections/experimental_soa_vector/SoaVector<T>] values) {
  return(/std/collections/soa_vector_conversions/soaVectorToAos<T>(values))
}

[public effects(heap_alloc), return<vector<T>>]
/std/collections/soa_vector/to_aos_ref<T>(
    [Reference</std/collections/experimental_soa_vector/SoaVector<T>>] values) {
  return(/std/collections/soa_vector_conversions/soaVectorToAosRef<T>(values))
}
