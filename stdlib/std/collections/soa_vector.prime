import /std/collections/experimental_soa_vector/*

[public return<i32>]
/std/collections/soa_vector/count<T>([SoaVector<T>] values) {
  return(/std/collections/experimental_soa_vector/soaVectorCount<T>(values))
}

[public return<T>]
/std/collections/soa_vector/get<T>([SoaVector<T>] values, [i32] index) {
  return(/std/collections/experimental_soa_vector/soaVectorGet<T>(values, index))
}

[public return<T>]
/std/collections/soa_vector/ref<T>([SoaVector<T>] values, [i32] index) {
  return(/std/collections/experimental_soa_vector/soaVectorRef<T>(values, index))
}

[public effects(heap_alloc), return<void>]
/std/collections/soa_vector/reserve<T>([SoaVector<T> mut] values, [i32] capacity) {
  /std/collections/experimental_soa_vector/soaVectorReserve<T>(values, capacity)
}

[public effects(heap_alloc), return<void>]
/std/collections/soa_vector/push<T>([SoaVector<T> mut] values, [T] value) {
  /std/collections/experimental_soa_vector/soaVectorPush<T>(values, value)
}
