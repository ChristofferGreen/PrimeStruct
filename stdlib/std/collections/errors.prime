[public return<string>]
/ContainerError/why([/std/collections/ContainerError] err) {
  return(/std/collections/ContainerError/why(err))
}

[public return<Result</std/collections/ContainerError>>]
/ContainerError/status([/std/collections/ContainerError] err) {
  return(/std/collections/ContainerError/status(err))
}

[public return</std/collections/ContainerError>]
/ContainerError/missingKey() {
  return(/std/collections/ContainerError/missingKey())
}

[public return</std/collections/ContainerError>]
/ContainerError/missing_key() {
  return(/ContainerError/missingKey())
}

[public return</std/collections/ContainerError>]
/ContainerError/indexOutOfBounds() {
  return(/std/collections/ContainerError/indexOutOfBounds())
}

[public return</std/collections/ContainerError>]
/ContainerError/index_out_of_bounds() {
  return(/ContainerError/indexOutOfBounds())
}

[public return</std/collections/ContainerError>]
/ContainerError/empty() {
  return(/std/collections/ContainerError/empty())
}

[public return</std/collections/ContainerError>]
/ContainerError/capacityExceeded() {
  return(/std/collections/ContainerError/capacityExceeded())
}

[public return</std/collections/ContainerError>]
/ContainerError/capacity_exceeded() {
