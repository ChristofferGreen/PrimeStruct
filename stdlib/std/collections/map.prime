import /std/collections/experimental_map/*

[public return<Entry<K, V>>]
/std/collections/map/entry<K, V>([K] key, [V] value) {
  return(/std/collections/experimental_map/entry<K, V>(key, value))
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/map/map<K, V>([args<Entry<K, V>>] entries) {
  [map<K, V> mut] out{/std/collections/experimental_map/mapNew<K, V>()}
  [i32] entryCount{count(entries)}
  [i32 mut] index{0i32}
  while(less_than(index, entryCount), do() {
    [Entry<K, V>] current{entries[index]}
    /std/collections/experimental_map/mapInsert<K, V>(out, current.key, current.value)
    increment(index)
  })
  return(out)
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/mapNew<K, V>() {
  return(/std/collections/map/map<K, V>())
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/mapSingle<K, V>([K] key, [V] value) {
  return(/std/collections/map/map<K, V>(/std/collections/map/entry<K, V>(key, value)))
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/mapDouble<K, V>([K] firstKey, [V] firstValue, [K] secondKey, [V] secondValue) {
  return(/std/collections/map/map<K, V>(
      /std/collections/map/entry<K, V>(firstKey, firstValue),
      /std/collections/map/entry<K, V>(secondKey, secondValue)))
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/mapPair<K, V>([K] firstKey, [V] firstValue, [K] secondKey, [V] secondValue) {
