  [return<i32> Comparable<K>]
  findIndex<K, V>([MapValue<K, V>] entries, [K] key) {
    [i32 mut] index{0i32}
    [Vector<K>] keys{entries.keys}
    [i32] limit{/std/collections/internal_vector/vectorCount<K>(keys)}
    while(less_than(index, limit), do() {
      if(/std/collections/map/keysEqual<K>(/std/collections/internal_vector/vectorAt<K>(keys, index), key),
         then() { return(index) },
         else() { })
      increment(index)
    })
    return(limit)
  }

  [return<i32> Comparable<K>]
  findIndexRef<K, V>([Reference<MapValue<K, V>>] entries, [K] key) {
    [i32 mut] index{0i32}
    [Vector<K>] keys{entries.keys}
    [i32] limit{/std/collections/internal_vector/vectorCount<K>(keys)}
    while(less_than(index, limit), do() {
      if(/std/collections/map/keysEqual<K>(/std/collections/internal_vector/vectorAt<K>(keys, index), key),
         then() { return(index) },
         else() { })
      increment(index)
    })
    return(limit)
  }

  [return<void>]
  overwriteSlot<T>([Vector<T> mut] values, [i32] index, [T] value) {
    [Reference<T> mut] slot{/std/collections/internal_vector/vectorBorrowSlot<T>(values, index)}
    assign(dereference(slot), value)
  }

  [public effects(heap_alloc), return<void> Comparable<K>]
  mapInsert<K, V>([MapValue<K, V> mut] entries, [K] key, [V] value) {
    [i32] index{/std/collections/map/findIndex<K, V>(entries, key)}
    [Vector<K> mut] keys{entries.keys}
    [Vector<V> mut] payloads{entries.payloads}
    if(less_than(index, /std/collections/map/mapCount<K, V>(entries)),
       then() {
         /std/collections/map/overwriteSlot<V>(payloads, index, value)
         assign(entries.payloads, payloads)
       },
       else() {
         /std/collections/internal_vector/vectorPush<K>(keys, key)
         /std/collections/internal_vector/vectorPush<V>(payloads, value)
         assign(entries.keys, keys)
         assign(entries.payloads, payloads)
       })
  }

