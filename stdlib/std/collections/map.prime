// Standalone canonical stdlib-owned map implementation.
// This module intentionally does not import the retired native map implementation.
import /std/collections/equality/*
import /std/collections/errors/*
import /std/collections/internal_vector/*

namespace std {
  namespace collections {
  namespace map {
  [public struct]
  Entry<K, V>() {
    [public K] key
    [public V] value
  }

  [public struct]
  MapValue<K, V>() {
    [public Vector<K> mut] keys{/std/collections/internal_vector/vector<K>()}
    [public Vector<V> mut] payloads{/std/collections/internal_vector/vector<V>()}

    [public return<i32>]
    mapCount() {
      [Vector<K>] keys{this.keys}
      return(/std/collections/internal_vector/vectorCount<K>(keys))
    }

    [public return<bool> Comparable<K>]
    mapContains([K] key) {
      [Vector<K>] keys{this.keys}
      [i32] limit{/std/collections/internal_vector/vectorCount<K>(keys)}
      return(less_than(
          /std/collections/map/findIndex<K, V>(this, key),
          limit))
    }

    [public return<Result<V, /std/collections/ContainerError>> Comparable<K>]
    mapTryAt([K] key) {
      [i32] index{/std/collections/map/findIndex<K, V>(this, key)}
      [Vector<V>] payloads{this.payloads}
      [Vector<K>] keys{this.keys}
      [i32] limit{/std/collections/internal_vector/vectorCount<K>(keys)}
      if(less_than(index, limit),
         then() { return(Result.ok(/std/collections/internal_vector/vectorAtUnsafe<V>(payloads, index))) },
         else() { return(/std/collections/ContainerError/result<V>(/std/collections/ContainerError/missingKey())) })
    }

    [public return<V> Comparable<K>]
    mapAt([K] key) {
      [i32] index{/std/collections/map/findIndex<K, V>(this, key)}
      [Vector<V>] payloads{this.payloads}
      [Vector<K>] keys{this.keys}
      [i32] limit{/std/collections/internal_vector/vectorCount<K>(keys)}
      if(less_than(index, limit),
         then() { return(/std/collections/internal_vector/vectorAtUnsafe<V>(payloads, index)) },
         else() { return(/std/collections/internal_vector/vectorAt<V>(payloads, index)) })
    }

    [public return<V> Comparable<K>]
    mapAtUnsafe([K] key) {
      [Vector<V>] payloads{this.payloads}
      return(/std/collections/internal_vector/vectorAtUnsafe<V>(
          payloads,
          /std/collections/map/findIndex<K, V>(this, key)))
    }

    [public effects(heap_alloc), return<void> Comparable<K>]
    mapInsert([K] key, [V] value) {
      [i32] index{/std/collections/map/findIndex<K, V>(this, key)}
      [Vector<K> mut] keys{this.keys}
      [Vector<V> mut] payloads{this.payloads}
      [i32] limit{/std/collections/internal_vector/vectorCount<K>(keys)}
      if(less_than(index, limit),
         then() {
           /std/collections/map/overwriteSlot<V>(payloads, index, value)
           assign(this.payloads, payloads)
         },
         else() {
           /std/collections/internal_vector/vectorPush<K>(keys, key)
           /std/collections/internal_vector/vectorPush<V>(payloads, value)
           assign(this.keys, keys)
           assign(this.payloads, payloads)
         })
    }

    [public mut]
    Move([Reference<Self>] other) {
      assign(this.keys, other.keys)
      assign(this.payloads, other.payloads)
      assign(other.keys, /std/collections/internal_vector/vector<K>())
      assign(other.payloads, /std/collections/internal_vector/vector<V>())
    }
  }

  [public return<Entry<K, V>>]
  entry<K, V>([K] key, [V] value) {
    return(Entry<K, V>{key, value})
  }

  [public effects(heap_alloc), return<MapValue<K, V>>]
  mapNew<K, V>() {
    return(MapValue<K, V>{})
  }

  [return<bool>]
  keysEqual<K>([K] left, [K] right) {
    return(left.equal(right))
  }

  [public effects(heap_alloc), return<MapValue<K, V>> Comparable<K>]
  map<K, V>([args<Entry<K, V>>] entries) {
    [MapValue<K, V> mut] out{mapNew<K, V>()}
    [i32] entryCount{count(entries)}
    [i32 mut] index{0i32}
    while(less_than(index, entryCount), do() {
      [Entry<K, V>] current{entries[index]}
      /std/collections/map/mapInsert<K, V>(out, current.key, current.value)
      increment(index)
    })
    return(out)
  }

  [public effects(heap_alloc), return<MapValue<K, V>> Comparable<K>]
  map<K, V>([K] firstKey, [V] firstValue) {
    [MapValue<K, V> mut] out{mapNew<K, V>()}
    /std/collections/map/mapInsert<K, V>(out, firstKey, firstValue)
    return(out)
  }

  [public effects(heap_alloc), return<MapValue<K, V>> Comparable<K>]
  map<K, V>([K] firstKey, [V] firstValue, [K] secondKey, [V] secondValue) {
    [MapValue<K, V> mut] out{mapNew<K, V>()}
    /std/collections/map/mapInsert<K, V>(out, firstKey, firstValue)
    /std/collections/map/mapInsert<K, V>(out, secondKey, secondValue)
    return(out)
  }

  [public return<i32>]
  mapCount<K, V>([MapValue<K, V>] entries) {
    [Vector<K>] keys{entries.keys}
    return(/std/collections/internal_vector/vectorCount<K>(keys))
  }

  [public return<i32>]
  mapCountRef<K, V>([Reference<MapValue<K, V>>] entries) {
    [Vector<K>] keys{entries.keys}
    return(/std/collections/internal_vector/vectorCount<K>(keys))
  }

  [public return<i32>]
  count<K, V>([MapValue<K, V>] entries) {
    return(/std/collections/map/mapCount<K, V>(entries))
  }

  [public return<i32>]
  count_ref<K, V>([Reference<MapValue<K, V>>] entries) {
