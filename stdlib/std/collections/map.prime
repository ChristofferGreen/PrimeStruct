// Canonical public wrapper layer over the internal_map implementation module.
import /std/collections/internal_map/*

[public return<Entry<K, V>>]
/std/collections/map/entry<K, V>([K] key, [V] value) {
  return(/std/collections/internal_map/entry<K, V>(key, value))
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/map/map<K, V>([args<Entry<K, V>>] entries) {
  [mut] out{/std/collections/internal_map/mapNew<K, V>()}
  entryCount{count(entries)}
  [mut] index{0i32}
  while(less_than(index, entryCount), do() {
    current{entries[index]}
    /std/collections/internal_map/insertImpl<K, V>(out, current.key, current.value)
    increment(index)
  })
  return(out)
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/map/map<K, V>([K] firstKey, [V] firstValue) {
  return(/std/collections/mapSingle<K, V>(firstKey, firstValue))
}

[public effects(heap_alloc), return<map<K, V>>]
/std/collections/map/map<K, V>([K] firstKey, [V] firstValue, [K] secondKey, [V] secondValue) {
  return(/std/collections/mapPair<K, V>(firstKey, firstValue, secondKey, secondValue))
}

