  [public return<void>]
  soaColumnWrite<T>([SoaColumn<T> mut] values, [i32] index, [T] value) {
    soaColumnCheckIndex<T>(values, index)
    soaColumnDropSlot<T>(values, index)
    soaColumnInitSlot<T>(values, index, value)
  }

  [public return<void>]
  soaColumns2Write<T0, T1>([SoaColumns2<T0, T1> mut] values,
                           [i32] index,
                           [T0] firstValue,
                           [T1] secondValue) {
    soaColumns2CheckShape<T0, T1>(values)
    [Reference<SoaColumn<T0>>] first{location(values.first)}
    [Reference<SoaColumn<T1>>] second{location(values.second)}
    soaColumnWrite<T0>(first, index, firstValue)
    soaColumnWrite<T1>(second, index, secondValue)
  }

