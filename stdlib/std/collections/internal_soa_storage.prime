  [public effects(heap_alloc), return<void>]
  soaColumns16Reserve<T0, T1, T2, T3, T4, T5, T6, T7, T8, T9, T10, T11, T12, T13, T14, T15>([SoaColumns16<T0, T1, T2, T3, T4, T5, T6, T7, T8, T9, T10, T11, T12, T13, T14, T15> mut] values,
                                                                                           [i32] capacity) {
    soaColumns16CheckShape<T0, T1, T2, T3, T4, T5, T6, T7, T8, T9, T10, T11, T12, T13, T14, T15>(values)
    [Reference<SoaColumn<T0>>] first{location(values.first)}
    [Reference<SoaColumn<T1>>] second{location(values.second)}
    [Reference<SoaColumn<T2>>] third{location(values.third)}
    [Reference<SoaColumn<T3>>] fourth{location(values.fourth)}
    [Reference<SoaColumn<T4>>] fifth{location(values.fifth)}
    [Reference<SoaColumn<T5>>] sixth{location(values.sixth)}
    [Reference<SoaColumn<T6>>] seventh{location(values.seventh)}
    [Reference<SoaColumn<T7>>] eighth{location(values.eighth)}
    [Reference<SoaColumn<T8>>] ninth{location(values.ninth)}
    [Reference<SoaColumn<T9>>] tenth{location(values.tenth)}
    [Reference<SoaColumn<T10>>] eleventh{location(values.eleventh)}
    [Reference<SoaColumn<T11>>] twelfth{location(values.twelfth)}
    [Reference<SoaColumn<T12>>] thirteenth{location(values.thirteenth)}
    [Reference<SoaColumn<T13>>] fourteenth{location(values.fourteenth)}
    [Reference<SoaColumn<T14>>] fifteenth{location(values.fifteenth)}
    [Reference<SoaColumn<T15>>] sixteenth{location(values.sixteenth)}
    soaColumnReserve<T0>(first, capacity)
    soaColumnReserve<T1>(second, capacity)
    soaColumnReserve<T2>(third, capacity)
    soaColumnReserve<T3>(fourth, capacity)
    soaColumnReserve<T4>(fifth, capacity)
    soaColumnReserve<T5>(sixth, capacity)
    soaColumnReserve<T6>(seventh, capacity)
    soaColumnReserve<T7>(eighth, capacity)
    soaColumnReserve<T8>(ninth, capacity)
    soaColumnReserve<T9>(tenth, capacity)
    soaColumnReserve<T10>(eleventh, capacity)
