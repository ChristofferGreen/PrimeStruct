                     or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T6>(seventh))),
                        or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T7>(eighth))),
                           or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T8>(ninth))),
                              or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T9>(tenth))),
                                 or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T10>(eleventh))),
                                    or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T11>(twelfth))),
                                       or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T12>(thirteenth))),
                                          or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T13>(fourteenth))),
                                             or(not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T14>(fifteenth))),
                                                not(equal(soaColumnCapacity<T0>(first), soaColumnCapacity<T15>(sixteenth)))))))))))))))))
    }
    if(or(countMismatch, capacityMismatch),
       then() {
         [array<i32>] empty{array<i32>()}
         empty[0i32]
       },
       else() { })
  }

