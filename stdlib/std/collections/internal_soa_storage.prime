  [return<Pointer<uninitialized<T>>>]
  soaColumnSlotUnsafe<T>([SoaColumn<T>] values, [i32] index) {
    soaColumnCheckShape<T>(values)
    if(or(less_than(index, 0i32),
          not(less_than(index, values.field_capacity()))),
       then() {
         [array<i32>] empty{array<i32>()}
         empty[index]
       },
       else() { })
    return(/std/collections/internal_buffer_unchecked/bufferOffsetUnsafe<uninitialized<T>>(values.data, index))
  }

  [public return<Pointer<uninitialized<Field>>>]
  soaColumnFieldSlotUnsafe<Struct, Field>([SoaColumn<Struct>] values, [i32] index, [i32] fieldIndex) {
    soaColumnCheckShape<Struct>(values)
    if(or(less_than(index, 0i32),
          not(less_than(index, values.field_capacity()))),
       then() {
         [array<i32>] empty{array<i32>()}
         empty[index]
       },
       else() { })
    [i32] fieldCount{/Struct/SoaSchemaFieldCount()}
    if(or(less_than(fieldIndex, 0i32),
          not(less_than(fieldIndex, fieldCount))),
       then() {
         [array<i32>] empty{array<i32>()}
         empty[fieldIndex]
       },
       else() { })
    [i32] stride{/Struct/SoaSchemaElementStride()}
    [i32] fieldOffset{/Struct/SoaSchemaFieldOffset(fieldIndex)}
    [i32] elementOffset{plus(multiply(index, stride), fieldOffset)}
    [Pointer<i32>] baseBytes{
        /std/collections/internal_buffer_unchecked/bufferReinterpretBytes<uninitialized<Struct>>(values.data)}
    [Pointer<i32>] fieldBytes{
        /std/collections/internal_buffer_unchecked/bufferOffsetBytesUnsafe(baseBytes, elementOffset)}
    return(/std/collections/internal_buffer_unchecked/bufferReinterpretFromBytes<uninitialized<Field>>(fieldBytes))
  }

  [public return<SoaFieldView<Field>>]
  soaColumnFieldViewUnsafe<Struct, Field>([SoaColumn<Struct>] values, [i32] fieldIndex) {
    soaColumnCheckShape<Struct>(values)
    [i32] fieldCount{/Struct/SoaSchemaFieldCount()}
    if(or(less_than(fieldIndex, 0i32),
          not(less_than(fieldIndex, fieldCount))),
       then() {
         [array<i32>] empty{array<i32>()}
         empty[fieldIndex]
       },
       else() { })
