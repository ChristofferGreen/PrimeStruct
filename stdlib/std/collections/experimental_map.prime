  }

  [public return<bool> Comparable<K>]
  mapContains<K, V>([Map<K, V>] entries, [K] key) {
    [Vector<K>] keys{entries.keys}
    return(less_than(mapFindIndex<K, V>(entries, key), /std/collections/experimental_vector/vectorCount<K>(keys)))
  }

  [public return<bool> Comparable<K>]
  mapContainsRef<K, V>([Reference<Map<K, V>>] entries, [K] key) {
    [Vector<K>] keys{entries.keys}
    return(less_than(mapFindIndexRef<K, V>(entries, key), /std/collections/experimental_vector/vectorCount<K>(keys)))
  }

