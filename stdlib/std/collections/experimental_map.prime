  [public return<V> Comparable<K>]
  mapAt<K, V>([Map<K, V>] entries, [K] key) {
    [i32] index{mapFindIndex<K, V>(entries, key)}
    [Vector<K>] keys{entries.keys}
    [Vector<V>] payloads{entries.payloads}
    if(less_than(index, /std/collections/experimental_vector/vectorCount<K>(keys)),
       then() { return(/std/collections/experimental_vector/vectorAtUnsafe<V>(payloads, index)) },
       else() {
         [map<K, V>] empty{/std/collections/map/map<K, V>()}
         return(/std/collections/map/at<K, V>(empty, key))
       })
  }

  [public return<V> Comparable<K>]
  mapAtRef<K, V>([Reference<Map<K, V>>] entries, [K] key) {
