  [public return<i32>]
  mapCount<K, V>([Map<K, V>] entries) {
    [Vector<K>] keys{entries.keys}
    return(/std/collections/experimental_vector/vectorCount<K>(keys))
  }

  [public return<i32>]
  mapCountRef<K, V>([Reference<Map<K, V>>] entries) {
    [Vector<K>] keys{entries.keys}
    return(/std/collections/experimental_vector/vectorCount<K>(keys))
  }

  [public return<i32>]
  /Reference/count<K, V>([Reference<Map<K, V>>] self) {
    return(mapCountRef<K, V>(self))
  }

  [public return<i32>]
  /std/collections/map/count_ref<K, V>([Reference<Map<K, V>>] values) {
