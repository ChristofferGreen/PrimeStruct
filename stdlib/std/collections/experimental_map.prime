  [public return<Result<V, ContainerError>> Comparable<K>]
  mapTryAt<K, V>([Map<K, V>] entries, [K] key) {
    [i32] index{mapFindIndex<K, V>(entries, key)}
    [Vector<K>] keys{entries.keys}
    [Vector<V>] payloads{entries.payloads}
    if(less_than(index, /std/collections/experimental_vector/vectorCount<K>(keys)),
       then() { return(Result.ok(/std/collections/experimental_vector/vectorAtUnsafe<V>(payloads, index))) },
       else() { return(containerErrorResult<V>(containerMissingKey())) })
  }

  [public return<Result<V, ContainerError>> Comparable<K>]
  mapTryAtRef<K, V>([Reference<Map<K, V>>] entries, [K] key) {
    [i32] index{mapFindIndexRef<K, V>(entries, key)}
    [Vector<K>] keys{entries.keys}
    [Vector<V>] payloads{entries.payloads}
