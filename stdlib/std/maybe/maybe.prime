namespace std {
  namespace maybe {
  [public sum]
  Maybe<T> {
    none
    [T] some
  }

  [public return<Maybe<T>>]
  some<T>([T] value) {
    return(Maybe<T>{[some] value})
  }

  [public return<Maybe<T>>]
  none<T>() {
    return(Maybe<T>{none})
  }

  [public return<bool>]
  /Maybe/isEmpty<T>([Maybe<T>] self) {
    return(pick(self) {
      none {
        return(true)
      }
      some(value) {
        return(false)
      }
    })
  }

  [public return<bool>]
  /Maybe/isSome<T>([Maybe<T>] self) {
    return(pick(self) {
      none {
        return(false)
      }
      some(value) {
        return(true)
      }
    })
  }

  [public return<bool>]
  /Maybe/is_empty<T>([Maybe<T>] self) {
    return(pick(self) {
      none {
        return(true)
      }
      some(value) {
        return(false)
      }
    })
  }

  [public return<bool>]
  /Maybe/is_some<T>([Maybe<T>] self) {
    return(pick(self) {
      none {
        return(false)
      }
      some(value) {
        return(true)
      }
    })
  }
  }
}
