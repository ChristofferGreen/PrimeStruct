namespace std {
  namespace maybe {
  [public struct]
  Maybe<T>() {
    [public bool] empty{true}
    [public uninitialized<T>] value{uninitialized<T>()}

    [public]
    Create() {
    }

    [public]
    Destroy() {
      if(not(this.empty), then() { drop(this.value) }, else() { })
    }
  }
  }
}
