namespace std {
  namespace ui {
  [public struct]
  Rgba8() {
    [public i32] r{0i32}
    [public i32] g{0i32}
    [public i32] b{0i32}
    [public i32] a{255i32}
  }

  [public struct]
  CommandList() {
    [public vector<i32> mut] records{vector<i32>()}
    [public i32 mut] commandCount{0i32}
    [i32 mut] clipDepth{0i32}
  }

  [public struct]
  HtmlCommandList() {
    [public vector<i32> mut] records{vector<i32>()}
    [public i32 mut] commandCount{0i32}
  }

  [public struct]
  LayoutTree() {
    [public vector<i32> mut] kinds{vector<i32>()}
    [public vector<i32> mut] parentIndices{vector<i32>()}
    [vector<i32> mut] paddingPxs{vector<i32>()}
    [vector<i32> mut] gapPxs{vector<i32>()}
    [vector<i32> mut] minWidths{vector<i32>()}
    [vector<i32> mut] minHeights{vector<i32>()}
    [vector<i32> mut] measuredWidths{vector<i32>()}
    [vector<i32> mut] measuredHeights{vector<i32>()}
    [vector<i32> mut] rectXs{vector<i32>()}
    [vector<i32> mut] rectYs{vector<i32>()}
    [vector<i32> mut] rectWidths{vector<i32>()}
    [vector<i32> mut] rectHeights{vector<i32>()}
  }

  [public struct]
  LoginFormNodes() {
    [public i32] panel{0i32}
    [public i32] title{0i32}
    [public i32] usernameInput{0i32}
    [public i32] passwordInput{0i32}
    [public i32] submitButton{0i32}
  }

  [return<i32>]
  widget_text_advance([i32] textSizePx) {
    return(max(1i32, divide(plus(textSizePx, 1i32), 2i32)))
  }

  [return<i32>]
  widget_text_width([i32] textSizePx, [string] text) {
    return(multiply(widget_text_advance(textSizePx), count(text)))
  }

  [return<i32>]
  widget_text_height([i32] textSizePx) {
    return(max(1i32, textSizePx))
  }

  [return<i32>]
  layout_inner_extent([i32] outerExtent, [i32] paddingPx) {
    return(max(0i32, minus(outerExtent, multiply(paddingPx, 2i32))))
  }

  namespace CommandList {
    [effects(heap_alloc), return<void>]
    append_word([CommandList mut] self, [i32] value) {
      push(self.records, value)
    }

    [effects(heap_alloc), return<void>]
    append_color([CommandList mut] self, [Rgba8] color) {
      self.append_word(color.r)
      self.append_word(color.g)
      self.append_word(color.b)
      self.append_word(color.a)
    }

    [public effects(heap_alloc), return<void>]
    draw_rounded_rect(
        [CommandList mut] self, [i32] x, [i32] y, [i32] width, [i32] height, [i32] radiusPx, [Rgba8] fill) {
      self.append_word(2i32)
      self.append_word(9i32)
      self.append_word(x)
      self.append_word(y)
      self.append_word(width)
      self.append_word(height)
      self.append_word(radiusPx)
      self.append_color(fill)
      assign(self.commandCount, plus(self.commandCount, 1i32))
    }

    [public effects(heap_alloc), return<void>]
    draw_text([CommandList mut] self, [i32] x, [i32] y, [i32] sizePx, [Rgba8] color, [string] text) {
      [i32] len{count(text)}
      self.append_word(1i32)
      self.append_word(plus(8i32, len))
      self.append_word(x)
      self.append_word(y)
      self.append_word(sizePx)
      self.append_color(color)
      self.append_word(len)
      for([i32 mut] index{0i32}, less_than(index, len), assign(index, plus(index, 1i32))) {
        self.append_word(text[index])
      }
      assign(self.commandCount, plus(self.commandCount, 1i32))
    }

    [public effects(heap_alloc), return<void>]
    draw_label(
        [CommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] textSizePx,
        [Rgba8] textColor,
        [string] text) {
      self.draw_text(layout.rect_x(nodeId), layout.rect_y(nodeId), textSizePx, textColor, text)
    }

    [public effects(heap_alloc), return<void>]
    draw_button(
        [CommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] textSizePx,
        [i32] paddingPx,
        [i32] radiusPx,
        [Rgba8] fill,
        [Rgba8] textColor,
        [string] text) {
      [i32] x{layout.rect_x(nodeId)}
      [i32] y{layout.rect_y(nodeId)}
      self.draw_rounded_rect(x, y, layout.rect_width(nodeId), layout.rect_height(nodeId), radiusPx, fill)
      self.draw_text(plus(x, paddingPx), plus(y, paddingPx), textSizePx, textColor, text)
    }

    [public effects(heap_alloc), return<void>]
    draw_input(
        [CommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] textSizePx,
        [i32] paddingPx,
        [i32] radiusPx,
        [Rgba8] fill,
        [Rgba8] textColor,
        [string] text) {
      [i32] x{layout.rect_x(nodeId)}
      [i32] y{layout.rect_y(nodeId)}
      self.draw_rounded_rect(x, y, layout.rect_width(nodeId), layout.rect_height(nodeId), radiusPx, fill)
      self.draw_text(plus(x, paddingPx), plus(y, paddingPx), textSizePx, textColor, text)
    }

    [public effects(heap_alloc), return<void>]
    begin_panel(
        [CommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] radiusPx,
        [Rgba8] fill) {
      [i32] x{layout.rect_x(nodeId)}
      [i32] y{layout.rect_y(nodeId)}
      [i32] paddingPx{layout.padding_px(nodeId)}
      self.draw_rounded_rect(x, y, layout.rect_width(nodeId), layout.rect_height(nodeId), radiusPx, fill)
      self.push_clip(
        plus(x, paddingPx),
        plus(y, paddingPx),
        layout_inner_extent(layout.rect_width(nodeId), paddingPx),
        layout_inner_extent(layout.rect_height(nodeId), paddingPx)
      )
    }

    [public effects(heap_alloc), return<void>]
    end_panel([CommandList mut] self) {
      self.pop_clip()
    }

    [public effects(heap_alloc), return<void>]
    draw_login_form(
        [CommandList mut] self,
        [LayoutTree] layout,
        [LoginFormNodes] nodes,
        [i32] textSizePx,
        [i32] inputPaddingPx,
        [i32] buttonPaddingPx,
        [i32] panelRadiusPx,
        [i32] controlRadiusPx,
        [Rgba8] panelFill,
        [Rgba8] titleColor,
        [Rgba8] inputFill,
        [Rgba8] inputTextColor,
        [Rgba8] buttonFill,
        [Rgba8] buttonTextColor,
        [string] title,
        [string] usernameText,
        [string] passwordText,
        [string] buttonText) {
      self.begin_panel(layout, nodes.panel, panelRadiusPx, panelFill)
      self.draw_label(layout, nodes.title, textSizePx, titleColor, title)
      self.draw_input(layout, nodes.usernameInput, textSizePx, inputPaddingPx, controlRadiusPx, inputFill, inputTextColor, usernameText)
      self.draw_input(layout, nodes.passwordInput, textSizePx, inputPaddingPx, controlRadiusPx, inputFill, inputTextColor, passwordText)
      self.draw_button(layout, nodes.submitButton, textSizePx, buttonPaddingPx, controlRadiusPx, buttonFill, buttonTextColor, buttonText)
      self.end_panel()
    }

    [public effects(heap_alloc), return<void>]
    push_clip([CommandList mut] self, [i32] x, [i32] y, [i32] width, [i32] height) {
      self.append_word(3i32)
      self.append_word(4i32)
      self.append_word(x)
      self.append_word(y)
      self.append_word(width)
      self.append_word(height)
      assign(self.commandCount, plus(self.commandCount, 1i32))
      assign(self.clipDepth, plus(self.clipDepth, 1i32))
    }

    [public effects(heap_alloc), return<void>]
    pop_clip([CommandList mut] self) {
      if(greater_than(self.clipDepth, 0i32)) {
        self.append_word(4i32)
        self.append_word(0i32)
        assign(self.commandCount, plus(self.commandCount, 1i32))
        assign(self.clipDepth, minus(self.clipDepth, 1i32))
      }
    }

    [public return<i32>]
    command_count([CommandList] self) {
      return(self.commandCount)
    }

    [public return<i32>]
    clip_depth([CommandList] self) {
      return(self.clipDepth)
    }

    [public effects(heap_alloc), return<vector<i32>>]
    serialize([CommandList] self) {
      [vector<i32> mut] words{vector<i32>()}
      [i32] len{count(self.records)}
      push(words, 1i32)
      push(words, self.commandCount)
      for([i32 mut] index{0i32}, less_than(index, len), assign(index, plus(index, 1i32))) {
        push(words, self.records[index])
      }
      return(words)
    }
  }

  namespace HtmlCommandList {
    [effects(heap_alloc), return<void>]
    append_word([HtmlCommandList mut] self, [i32] value) {
      push(self.records, value)
    }

    [effects(heap_alloc), return<void>]
    append_color([HtmlCommandList mut] self, [Rgba8] color) {
      self.append_word(color.r)
      self.append_word(color.g)
      self.append_word(color.b)
      self.append_word(color.a)
    }

    [effects(heap_alloc), return<void>]
    append_string([HtmlCommandList mut] self, [string] text) {
      [i32] len{count(text)}
      self.append_word(len)
      for([i32 mut] index{0i32}, less_than(index, len), assign(index, plus(index, 1i32))) {
        self.append_word(text[index])
      }
    }

    [public effects(heap_alloc), return<void>]
    emit_panel(
        [HtmlCommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] radiusPx,
        [Rgba8] fill) {
      self.append_word(1i32)
      self.append_word(12i32)
      self.append_word(nodeId)
      self.append_word(layout.parent_index(nodeId))
      self.append_word(layout.rect_x(nodeId))
      self.append_word(layout.rect_y(nodeId))
      self.append_word(layout.rect_width(nodeId))
      self.append_word(layout.rect_height(nodeId))
      self.append_word(layout.padding_px(nodeId))
      self.append_word(radiusPx)
      self.append_color(fill)
      assign(self.commandCount, plus(self.commandCount, 1i32))
    }

    [public effects(heap_alloc), return<void>]
    emit_label(
        [HtmlCommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] textSizePx,
        [Rgba8] textColor,
        [string] text) {
      [i32] len{count(text)}
      self.append_word(2i32)
      self.append_word(plus(12i32, len))
      self.append_word(nodeId)
      self.append_word(layout.parent_index(nodeId))
      self.append_word(layout.rect_x(nodeId))
      self.append_word(layout.rect_y(nodeId))
      self.append_word(layout.rect_width(nodeId))
      self.append_word(layout.rect_height(nodeId))
      self.append_word(textSizePx)
      self.append_color(textColor)
      self.append_string(text)
      assign(self.commandCount, plus(self.commandCount, 1i32))
    }

    [public effects(heap_alloc), return<void>]
    emit_button(
        [HtmlCommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] textSizePx,
        [i32] paddingPx,
        [i32] radiusPx,
        [Rgba8] fill,
        [Rgba8] textColor,
        [string] text,
        [string] clickHandler) {
      [i32] len{text.count()}
      self.append_word(3i32)
      self.append_word(plus(18i32, len))
      self.append_word(nodeId)
      self.append_word(layout.parent_index(nodeId))
      self.append_word(layout.rect_x(nodeId))
      self.append_word(layout.rect_y(nodeId))
      self.append_word(layout.rect_width(nodeId))
      self.append_word(layout.rect_height(nodeId))
      self.append_word(textSizePx)
      self.append_word(paddingPx)
      self.append_word(radiusPx)
      self.append_color(fill)
      self.append_color(textColor)
      self.append_string(text)
      assign(self.commandCount, plus(self.commandCount, 1i32))
      self.bind_event(nodeId, 1i32, clickHandler)
    }

    [public effects(heap_alloc), return<void>]
    emit_input(
        [HtmlCommandList mut] self,
        [LayoutTree] layout,
        [i32] nodeId,
        [i32] textSizePx,
        [i32] paddingPx,
        [i32] radiusPx,
        [Rgba8] fill,
        [Rgba8] textColor,
        [string] text,
        [string] inputHandler) {
      [i32] len{text.count()}
      self.append_word(4i32)
      self.append_word(plus(18i32, len))
      self.append_word(nodeId)
      self.append_word(layout.parent_index(nodeId))
      self.append_word(layout.rect_x(nodeId))
      self.append_word(layout.rect_y(nodeId))
      self.append_word(layout.rect_width(nodeId))
      self.append_word(layout.rect_height(nodeId))
      self.append_word(textSizePx)
      self.append_word(paddingPx)
      self.append_word(radiusPx)
      self.append_color(fill)
      self.append_color(textColor)
      self.append_string(text)
      assign(self.commandCount, plus(self.commandCount, 1i32))
      self.bind_event(nodeId, 2i32, inputHandler)
    }

    [public effects(heap_alloc), return<void>]
    bind_event([HtmlCommandList mut] self, [i32] nodeId, [i32] eventKind, [string] handlerName) {
      [i32] len{handlerName.count()}
      self.append_word(5i32)
      self.append_word(plus(3i32, len))
      self.append_word(nodeId)
      self.append_word(eventKind)
      self.append_string(handlerName)
      assign(self.commandCount, plus(self.commandCount, 1i32))
    }

    [public effects(heap_alloc), return<void>]
    emit_login_form(
        [HtmlCommandList mut] self,
        [LayoutTree] layout,
        [LoginFormNodes] nodes,
        [i32] textSizePx,
        [i32] inputPaddingPx,
        [i32] buttonPaddingPx,
        [i32] panelRadiusPx,
        [i32] controlRadiusPx,
        [Rgba8] panelFill,
        [Rgba8] titleColor,
        [Rgba8] inputFill,
        [Rgba8] inputTextColor,
        [Rgba8] buttonFill,
        [Rgba8] buttonTextColor,
        [string] title,
        [string] usernameText,
        [string] passwordText,
        [string] buttonText,
        [string] usernameInputHandler,
        [string] passwordInputHandler,
        [string] submitClickHandler) {
      self.emit_panel(layout, nodes.panel, panelRadiusPx, panelFill)
      self.emit_label(layout, nodes.title, textSizePx, titleColor, title)
      self.emit_input(layout, nodes.usernameInput, textSizePx, inputPaddingPx, controlRadiusPx, inputFill, inputTextColor, usernameText, usernameInputHandler)
      self.emit_input(layout, nodes.passwordInput, textSizePx, inputPaddingPx, controlRadiusPx, inputFill, inputTextColor, passwordText, passwordInputHandler)
      self.emit_button(layout, nodes.submitButton, textSizePx, buttonPaddingPx, controlRadiusPx, buttonFill, buttonTextColor, buttonText, submitClickHandler)
    }

    [public effects(heap_alloc), return<vector<i32>>]
    serialize([HtmlCommandList] self) {
      [vector<i32> mut] words{vector<i32>()}
      [i32] len{count(self.records)}
      push(words, 1i32)
      push(words, self.commandCount)
      for([i32 mut] index{0i32}, less_than(index, len), assign(index, plus(index, 1i32))) {
        push(words, self.records[index])
      }
      return(words)
    }
  }

  namespace LayoutTree {
    [effects(heap_alloc), return<i32>]
    append_node(
        [LayoutTree mut] self,
        [i32] kind,
        [i32] parentIndex,
        [i32] paddingPx,
        [i32] gapPx,
        [i32] minWidth,
        [i32] minHeight) {
      [i32] nodeId{count(self.kinds)}
      push(self.kinds, kind)
      push(self.parentIndices, parentIndex)
      push(self.paddingPxs, paddingPx)
      push(self.gapPxs, gapPx)
      push(self.minWidths, minWidth)
      push(self.minHeights, minHeight)
      push(self.measuredWidths, 0i32)
      push(self.measuredHeights, 0i32)
      push(self.rectXs, 0i32)
      push(self.rectYs, 0i32)
      push(self.rectWidths, 0i32)
      push(self.rectHeights, 0i32)
      return(nodeId)
    }

    [return<void>]
    assign_rect([LayoutTree mut] self, [i32] nodeId, [i32] x, [i32] y, [i32] width, [i32] height) {
      assign(self.rectXs[nodeId], x)
      assign(self.rectYs[nodeId], y)
      assign(self.rectWidths[nodeId], width)
      assign(self.rectHeights[nodeId], height)
    }

    [public effects(heap_alloc), return<i32>]
    append_root_column([LayoutTree mut] self, [i32] paddingPx, [i32] gapPx, [i32] minWidth, [i32] minHeight) {
      return(self.append_node(2i32, -1i32, paddingPx, gapPx, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<i32>]
    append_column(
        [LayoutTree mut] self, [i32] parentIndex, [i32] paddingPx, [i32] gapPx, [i32] minWidth, [i32] minHeight) {
      return(self.append_node(2i32, parentIndex, paddingPx, gapPx, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<i32>]
    append_panel(
        [LayoutTree mut] self, [i32] parentIndex, [i32] paddingPx, [i32] gapPx, [i32] minWidth, [i32] minHeight) {
      return(self.append_column(parentIndex, paddingPx, gapPx, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<LoginFormNodes>]
    append_login_form(
        [LayoutTree mut] self,
        [i32] parentIndex,
        [i32] panelPaddingPx,
        [i32] panelGapPx,
        [i32] textSizePx,
        [i32] inputPaddingPx,
        [i32] buttonPaddingPx,
        [i32] inputMinWidth,
        [string] title,
        [string] usernameText,
        [string] passwordText,
        [string] buttonText) {
      [i32] panel{self.append_panel(parentIndex, panelPaddingPx, panelGapPx, 0i32, 0i32)}
      [i32] titleNode{self.append_label(panel, textSizePx, title)}
      [i32] usernameNode{self.append_input(panel, textSizePx, inputPaddingPx, inputMinWidth, usernameText)}
      [i32] passwordNode{self.append_input(panel, textSizePx, inputPaddingPx, inputMinWidth, passwordText)}
      [i32] submitNode{self.append_button(panel, textSizePx, buttonPaddingPx, buttonText)}
      return(LoginFormNodes(
        [panel] panel,
        [title] titleNode,
        [usernameInput] usernameNode,
        [passwordInput] passwordNode,
        [submitButton] submitNode
      ))
    }

    [public effects(heap_alloc), return<i32>]
    append_leaf([LayoutTree mut] self, [i32] parentIndex, [i32] minWidth, [i32] minHeight) {
      return(self.append_node(1i32, parentIndex, 0i32, 0i32, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<i32>]
    append_label([LayoutTree mut] self, [i32] parentIndex, [i32] textSizePx, [string] text) {
      return(self.append_leaf(parentIndex, widget_text_width(textSizePx, text), widget_text_height(textSizePx)))
    }

    [public effects(heap_alloc), return<i32>]
    append_button([LayoutTree mut] self, [i32] parentIndex, [i32] textSizePx, [i32] paddingPx, [string] text) {
      return(self.append_leaf(
        parentIndex,
        plus(widget_text_width(textSizePx, text), multiply(paddingPx, 2i32)),
        plus(widget_text_height(textSizePx), multiply(paddingPx, 2i32))
      ))
    }

    [public effects(heap_alloc), return<i32>]
    append_input(
        [LayoutTree mut] self, [i32] parentIndex, [i32] textSizePx, [i32] paddingPx, [i32] minWidth, [string] text) {
      [i32] contentWidth{plus(widget_text_width(textSizePx, text), multiply(paddingPx, 2i32))}
      return(self.append_leaf(
        parentIndex,
        max(minWidth, contentWidth),
        plus(widget_text_height(textSizePx), multiply(paddingPx, 2i32))
      ))
    }

    [public return<i32>]
    node_count([LayoutTree] self) {
      return(count(self.kinds))
    }

    [public return<i32>]
    measured_width([LayoutTree] self, [i32] nodeId) {
      return(self.measuredWidths[nodeId])
    }

    [public return<i32>]
    measured_height([LayoutTree] self, [i32] nodeId) {
      return(self.measuredHeights[nodeId])
    }

    [public return<i32>]
    rect_x([LayoutTree] self, [i32] nodeId) {
      return(self.rectXs[nodeId])
    }

    [public return<i32>]
    rect_y([LayoutTree] self, [i32] nodeId) {
      return(self.rectYs[nodeId])
    }

    [public return<i32>]
    rect_width([LayoutTree] self, [i32] nodeId) {
      return(self.rectWidths[nodeId])
    }

    [public return<i32>]
    rect_height([LayoutTree] self, [i32] nodeId) {
      return(self.rectHeights[nodeId])
    }

    [return<i32>]
    padding_px([LayoutTree] self, [i32] nodeId) {
      return(self.paddingPxs[nodeId])
    }

    [return<i32>]
    parent_index([LayoutTree] self, [i32] nodeId) {
      return(self.parentIndices[nodeId])
    }

    [public return<void>]
    measure([LayoutTree mut] self) {
      [i32 mut] nodeId{minus(count(self.kinds), 1i32)}
      while(greater_equal(nodeId, 0i32)) {
        if(equal(self.kinds[nodeId], 1i32)) {
          assign(self.measuredWidths[nodeId], self.minWidths[nodeId])
          assign(self.measuredHeights[nodeId], self.minHeights[nodeId])
        } else {
          [i32 mut] maxChildWidth{0i32}
          [i32 mut] totalChildHeight{0i32}
          [i32 mut] childCount{0i32}
          [i32] totalNodes{count(self.kinds)}
          for([i32 mut] childId{0i32}, less_than(childId, totalNodes), assign(childId, plus(childId, 1i32))) {
            if(equal(self.parentIndices[childId], nodeId)) {
              assign(maxChildWidth, max(maxChildWidth, self.measuredWidths[childId]))
              assign(totalChildHeight, plus(totalChildHeight, self.measuredHeights[childId]))
              assign(childCount, plus(childCount, 1i32))
            }
          }
          [i32] gapCount{max(0i32, minus(childCount, 1i32))}
          [i32] contentWidth{plus(maxChildWidth, multiply(self.paddingPxs[nodeId], 2i32))}
          [i32] contentHeight{
            plus(
              plus(totalChildHeight, multiply(self.gapPxs[nodeId], gapCount)),
              multiply(self.paddingPxs[nodeId], 2i32)
            )
          }
          assign(self.measuredWidths[nodeId], max(self.minWidths[nodeId], contentWidth))
          assign(self.measuredHeights[nodeId], max(self.minHeights[nodeId], contentHeight))
        }
        assign(nodeId, minus(nodeId, 1i32))
      }
    }

    [public return<void>]
    arrange([LayoutTree mut] self, [i32] rootX, [i32] rootY, [i32] rootWidth, [i32] rootHeight) {
      if(equal(count(self.kinds), 0i32)) {
        return()
      }

      self.assign_rect(0i32, rootX, rootY, rootWidth, rootHeight)

      [i32] totalNodes{count(self.kinds)}
      for([i32 mut] nodeId{0i32}, less_than(nodeId, totalNodes), assign(nodeId, plus(nodeId, 1i32))) {
        if(equal(self.kinds[nodeId], 2i32)) {
          [i32] paddingPx{self.paddingPxs[nodeId]}
          [i32] innerX{plus(self.rectXs[nodeId], paddingPx)}
          [i32] innerY{plus(self.rectYs[nodeId], paddingPx)}
          [i32] innerWidth{max(0i32, minus(self.rectWidths[nodeId], multiply(paddingPx, 2i32)))}
          [i32 mut] childY{innerY}

          for([i32 mut] childId{0i32}, less_than(childId, totalNodes), assign(childId, plus(childId, 1i32))) {
            if(equal(self.parentIndices[childId], nodeId)) {
              self.assign_rect(childId, innerX, childY, innerWidth, self.measuredHeights[childId])
              assign(childY, plus(childY, plus(self.measuredHeights[childId], self.gapPxs[nodeId])))
            }
          }
        }
      }
    }

    [public effects(heap_alloc), return<vector<i32>>]
    serialize([LayoutTree] self) {
      [vector<i32> mut] words{vector<i32>()}
      [i32] totalNodes{count(self.kinds)}
      push(words, 1i32)
      push(words, totalNodes)
      for([i32 mut] nodeId{0i32}, less_than(nodeId, totalNodes), assign(nodeId, plus(nodeId, 1i32))) {
        push(words, self.kinds[nodeId])
        push(words, self.parentIndices[nodeId])
        push(words, self.measuredWidths[nodeId])
        push(words, self.measuredHeights[nodeId])
        push(words, self.rectXs[nodeId])
        push(words, self.rectYs[nodeId])
        push(words, self.rectWidths[nodeId])
        push(words, self.rectHeights[nodeId])
      }
      return(words)
    }
  }
  }
}
