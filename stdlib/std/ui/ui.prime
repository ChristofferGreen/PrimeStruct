  namespace LayoutTree {
    [effects(heap_alloc), return<i32>]
    append_node(
        [LayoutTree mut] self,
        [i32] kind,
        [i32] parentIndex,
        [i32] paddingPx,
        [i32] gapPx,
        [i32] minWidth,
        [i32] minHeight) {
      [mut] kinds{self.kinds}
      [mut] parentIndices{self.parentIndices}
      [mut] paddingPxs{self.paddingPxs}
      [mut] gapPxs{self.gapPxs}
      [mut] minWidths{self.minWidths}
      [mut] minHeights{self.minHeights}
      [mut] measuredWidths{self.measuredWidths}
      [mut] measuredHeights{self.measuredHeights}
      [mut] rectXs{self.rectXs}
      [mut] rectYs{self.rectYs}
      [mut] rectWidths{self.rectWidths}
      [mut] rectHeights{self.rectHeights}
      nodeId{count(kinds)}
      kinds.push(kind)
      parentIndices.push(parentIndex)
      paddingPxs.push(paddingPx)
      gapPxs.push(gapPx)
      minWidths.push(minWidth)
      minHeights.push(minHeight)
      measuredWidths.push(0i32)
      measuredHeights.push(0i32)
      rectXs.push(0i32)
      rectYs.push(0i32)
      rectWidths.push(0i32)
      rectHeights.push(0i32)
      self.kinds = kinds
      self.parentIndices = parentIndices
      self.paddingPxs = paddingPxs
      self.gapPxs = gapPxs
      self.minWidths = minWidths
      self.minHeights = minHeights
      self.measuredWidths = measuredWidths
      self.measuredHeights = measuredHeights
      self.rectXs = rectXs
      self.rectYs = rectYs
      self.rectWidths = rectWidths
      self.rectHeights = rectHeights
      return(nodeId)
    }

    [return<void>]
    assign_rect([LayoutTree mut] self, [i32] nodeId, [i32] x, [i32] y, [i32] width, [i32] height) {
      self.rectXs[nodeId] = x
      self.rectYs[nodeId] = y
      self.rectWidths[nodeId] = width
      self.rectHeights[nodeId] = height
    }

    [public effects(heap_alloc), return<i32>]
    append_root_column([LayoutTree mut] self, [i32] paddingPx, [i32] gapPx, [i32] minWidth, [i32] minHeight) {
      return(self.append_node(2i32, -1i32, paddingPx, gapPx, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<i32>]
    append_column(
        [LayoutTree mut] self, [i32] parentIndex, [i32] paddingPx, [i32] gapPx, [i32] minWidth, [i32] minHeight) {
      return(self.append_node(2i32, parentIndex, paddingPx, gapPx, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<i32>]
    append_panel(
        [LayoutTree mut] self, [i32] parentIndex, [i32] paddingPx, [i32] gapPx, [i32] minWidth, [i32] minHeight) {
      return(self.append_column(parentIndex, paddingPx, gapPx, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<LoginFormNodes>]
    append_login_form(
        [LayoutTree mut] self,
        [i32] parentIndex,
        [i32] panelPaddingPx,
        [i32] panelGapPx,
        [i32] textSizePx,
        [i32] inputPaddingPx,
        [i32] buttonPaddingPx,
        [i32] inputMinWidth,
        [string] title,
        [string] usernameText,
        [string] passwordText,
        [string] buttonText) {
      panel{self.append_panel(parentIndex, panelPaddingPx, panelGapPx, 0i32, 0i32)}
      titleNode{self.append_label(panel, textSizePx, title)}
      usernameNode{self.append_input(panel, textSizePx, inputPaddingPx, inputMinWidth, usernameText)}
      passwordNode{self.append_input(panel, textSizePx, inputPaddingPx, inputMinWidth, passwordText)}
      submitNode{self.append_button(panel, textSizePx, buttonPaddingPx, buttonText)}
      return(LoginFormNodes(
        [panel] panel,
        [title] titleNode,
        [usernameInput] usernameNode,
        [passwordInput] passwordNode,
        [submitButton] submitNode
      ))
    }

    [public effects(heap_alloc), return<i32>]
    append_leaf([LayoutTree mut] self, [i32] parentIndex, [i32] minWidth, [i32] minHeight) {
      return(self.append_node(1i32, parentIndex, 0i32, 0i32, minWidth, minHeight))
    }

    [public effects(heap_alloc), return<i32>]
    append_label([LayoutTree mut] self, [i32] parentIndex, [i32] textSizePx, [string] text) {
      return(self.append_leaf(parentIndex, widget_text_width(textSizePx, text), widget_text_height(textSizePx)))
    }

    [public effects(heap_alloc), return<i32>]
    append_button([LayoutTree mut] self, [i32] parentIndex, [i32] textSizePx, [i32] paddingPx, [string] text) {
      return(self.append_leaf(
        parentIndex,
        widget_text_width(textSizePx, text) + multiply(paddingPx, 2i32),
        widget_text_height(textSizePx) + multiply(paddingPx, 2i32)
      ))
    }

    [public effects(heap_alloc), return<i32>]
    append_input(
        [LayoutTree mut] self, [i32] parentIndex, [i32] textSizePx, [i32] paddingPx, [i32] minWidth, [string] text) {
      contentWidth{widget_text_width(textSizePx, text) + multiply(paddingPx, 2i32)}
      return(self.append_leaf(
        parentIndex,
        /std/math/max(minWidth, contentWidth),
        widget_text_height(textSizePx) + multiply(paddingPx, 2i32)
      ))
    }

    [public return<i32>]
    node_count([LayoutTree] self) {
      return(count(self.kinds))
    }

    [public return<i32>]
    measured_width([LayoutTree] self, [i32] nodeId) {
      return(self.measuredWidths[nodeId])
    }

    [public return<i32>]
    measured_height([LayoutTree] self, [i32] nodeId) {
      return(self.measuredHeights[nodeId])
    }

    [public return<i32>]
    rect_x([LayoutTree] self, [i32] nodeId) {
      return(self.rectXs[nodeId])
    }

    [public return<i32>]
    rect_y([LayoutTree] self, [i32] nodeId) {
      return(self.rectYs[nodeId])
    }

    [public return<i32>]
    rect_width([LayoutTree] self, [i32] nodeId) {
      return(self.rectWidths[nodeId])
    }

    [public return<i32>]
    rect_height([LayoutTree] self, [i32] nodeId) {
      return(self.rectHeights[nodeId])
    }

    [return<i32>]
    padding_px([LayoutTree] self, [i32] nodeId) {
      return(self.paddingPxs[nodeId])
    }

    [return<i32>]
    parent_index([LayoutTree] self, [i32] nodeId) {
      return(self.parentIndices[nodeId])
    }

    [public return<void>]
    measure([LayoutTree mut] self) {
      [i32 mut] nodeId{count(self.kinds) - 1i32}
      while(greater_equal(nodeId, 0i32)) {
        if(equal(self.kinds[nodeId], 1i32)) {
          self.measuredWidths[nodeId] = self.minWidths[nodeId]
          self.measuredHeights[nodeId] = self.minHeights[nodeId]
        } else {
          [i32 mut] maxChildWidth{0i32}
          [i32 mut] totalChildHeight{0i32}
          [i32 mut] childCount{0i32}
          totalNodes{count(self.kinds)}
          for([i32 mut] childId{0i32}, less_than(childId, totalNodes), ++childId) {
            if(equal(self.parentIndices[childId], nodeId)) {
              maxChildWidth = /std/math/max(maxChildWidth, self.measuredWidths[childId])
              totalChildHeight = totalChildHeight + self.measuredHeights[childId]
              childCount = childCount + 1i32
            }
          }
          gapCount{/std/math/max(0i32, childCount - 1i32)}
          contentWidth{maxChildWidth + multiply(self.paddingPxs[nodeId], 2i32)}
          contentHeight{
            totalChildHeight + multiply(self.gapPxs[nodeId], gapCount) +
            multiply(self.paddingPxs[nodeId], 2i32)
          }
          self.measuredWidths[nodeId] = /std/math/max(self.minWidths[nodeId], contentWidth)
          self.measuredHeights[nodeId] = /std/math/max(self.minHeights[nodeId], contentHeight)
        }
        --nodeId
      }
    }

    [public return<void>]
    arrange([LayoutTree mut] self, [i32] rootX, [i32] rootY, [i32] rootWidth, [i32] rootHeight) {
      if(equal(count(self.kinds), 0i32)) {
        return()
      }

      self.assign_rect(0i32, rootX, rootY, rootWidth, rootHeight)

      totalNodes{count(self.kinds)}
      for([i32 mut] nodeId{0i32}, less_than(nodeId, totalNodes), ++nodeId) {
        if(equal(self.kinds[nodeId], 2i32)) {
          paddingPx{self.paddingPxs[nodeId]}
          innerX{self.rectXs[nodeId] + paddingPx}
          innerY{self.rectYs[nodeId] + paddingPx}
          innerWidth{/std/math/max(0i32, self.rectWidths[nodeId] - multiply(paddingPx, 2i32))}
          [i32 mut] childY{innerY}

          for([i32 mut] childId{0i32}, less_than(childId, totalNodes), ++childId) {
            if(equal(self.parentIndices[childId], nodeId)) {
              self.assign_rect(childId, innerX, childY, innerWidth, self.measuredHeights[childId])
              childY = childY + self.measuredHeights[childId] + self.gapPxs[nodeId]
            }
          }
        }
      }
    }

    [public effects(heap_alloc), return<vector<i32>>]
    serialize([LayoutTree] self) {
      [mut] words{vector<i32>()}
      totalNodes{count(self.kinds)}
      words.push(1i32)
      words.push(totalNodes)
      for([i32 mut] nodeId{0i32}, less_than(nodeId, totalNodes), ++nodeId) {
        words.push(self.kinds[nodeId])
        words.push(self.parentIndices[nodeId])
        words.push(self.measuredWidths[nodeId])
        words.push(self.measuredHeights[nodeId])
        words.push(self.rectXs[nodeId])
        words.push(self.rectYs[nodeId])
        words.push(self.rectWidths[nodeId])
        words.push(self.rectHeights[nodeId])
      }
      return(words)
    }
  }
  }
}
