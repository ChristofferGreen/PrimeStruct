  [effects(heap_alloc), return<int>]
  pngReadDynamicHuffmanLengths([vector<i32>] compressed, [i32 mut] byteIndex, [i32 mut] bitIndex,
                               [i32] codeLengthCodeCount, [i32] literalCount, [i32] distanceCount,
                               [vector<i32> mut] literalLengthsLow, [vector<i32> mut] literalLengthsHigh,
                               [vector<i32> mut] distanceLengths) {
    clear(literalLengthsLow)
    clear(literalLengthsHigh)
    clear(distanceLengths)

    [vector<i32> mut] codeLengthLengths{vector<i32>()}
    [i32 mut] codeLengthIndex{0i32}
    while(less_than(codeLengthIndex, 19i32), do() {
      push(codeLengthLengths, 0i32)
      increment(codeLengthIndex)
    })

    [i32 mut] orderIndex{0i32}
    while(less_than(orderIndex, codeLengthCodeCount), do() {
      [i32] codeLengthSymbol{pngCodeLengthCodeOrder(orderIndex)}
      if(less_than(codeLengthSymbol, 0i32),
         then() { return(1i32) },
         else() { })
      [i32 mut] lengthValue{0i32}
      [i32] lengthStatus{pngReadBits(compressed, byteIndex, bitIndex, 3i32, lengthValue)}
      if(not_equal(lengthStatus, 0i32),
         then() { return(1i32) },
         else() { })
      assign(codeLengthLengths[codeLengthSymbol], lengthValue)
      increment(orderIndex)
    })

    [i32] codeLengthMaxBits{pngHuffmanMaxBits(codeLengthLengths)}
    if(less_equal(codeLengthMaxBits, 0i32),
       then() { return(1i32) },
       else() { })

    [i32] totalCodeCount{plus(literalCount, distanceCount)}
    [i32 mut] position{0i32}
    [i32 mut] previousLength{0i32}
    while(less_than(position, totalCodeCount), do() {
      [i32 mut] symbol{0i32}
      [i32] symbolStatus{pngHuffmanDecodeSymbol(compressed, byteIndex, bitIndex, codeLengthLengths, codeLengthMaxBits,
                                                symbol)}
      if(not_equal(symbolStatus, 0i32),
         then() { return(1i32) },
         else() { })
      if(less_equal(symbol, 15i32),
         then() {
           if(less_than(position, literalCount),
              then() {
                if(less_than(position, 256i32),
                   then() { push(literalLengthsLow, symbol) },
                   else() { push(literalLengthsHigh, symbol) })
              },
              else() { push(distanceLengths, symbol) })
           assign(previousLength, symbol)
           increment(position)
         },
         else() {
           if(equal(symbol, 16i32),
              then() {
                if(equal(position, 0i32),
                   then() { return(1i32) },
                   else() { })
                [i32 mut] repeatExtra{0i32}
                [i32] repeatStatus{pngReadBits(compressed, byteIndex, bitIndex, 2i32, repeatExtra)}
                if(not_equal(repeatStatus, 0i32),
                   then() { return(1i32) },
                   else() { })
                [i32] repeatCount{plus(3i32, repeatExtra)}
                if(greater_than(plus(position, repeatCount), totalCodeCount),
                   then() { return(1i32) },
                   else() { })
                [i32 mut] repeatIndex{0i32}
                while(less_than(repeatIndex, repeatCount), do() {
                  if(less_than(position, literalCount),
                     then() {
                       if(less_than(position, 256i32),
                          then() { push(literalLengthsLow, previousLength) },
                          else() { push(literalLengthsHigh, previousLength) })
                     },
                     else() { push(distanceLengths, previousLength) })
                  increment(position)
                  increment(repeatIndex)
                })
              },
              else() {
                if(equal(symbol, 17i32),
                   then() {
                     [i32 mut] repeatExtra{0i32}
                     [i32] repeatStatus{pngReadBits(compressed, byteIndex, bitIndex, 3i32, repeatExtra)}
                     if(not_equal(repeatStatus, 0i32),
                        then() { return(1i32) },
                        else() { })
                     [i32] repeatCount{plus(3i32, repeatExtra)}
                     if(greater_than(plus(position, repeatCount), totalCodeCount),
                        then() { return(1i32) },
                        else() { })
                     [i32 mut] repeatIndex{0i32}
                     while(less_than(repeatIndex, repeatCount), do() {
                       if(less_than(position, literalCount),
                          then() {
                            if(less_than(position, 256i32),
                               then() { push(literalLengthsLow, 0i32) },
                               else() { push(literalLengthsHigh, 0i32) })
                          },
                          else() { push(distanceLengths, 0i32) })
                       assign(previousLength, 0i32)
                       increment(position)
                       increment(repeatIndex)
                     })
                   },
                   else() {
                     if(equal(symbol, 18i32),
                        then() {
                          [i32 mut] repeatExtra{0i32}
                          [i32] repeatStatus{pngReadBits(compressed, byteIndex, bitIndex, 7i32, repeatExtra)}
                          if(not_equal(repeatStatus, 0i32),
                             then() { return(1i32) },
                             else() { })
                          [i32] repeatCount{plus(11i32, repeatExtra)}
                          if(greater_than(plus(position, repeatCount), totalCodeCount),
                             then() { return(1i32) },
                             else() { })
                          [i32 mut] repeatIndex{0i32}
                          while(less_than(repeatIndex, repeatCount), do() {
                            if(less_than(position, literalCount),
                               then() {
                                 if(less_than(position, 256i32),
                                    then() { push(literalLengthsLow, 0i32) },
                                    else() { push(literalLengthsHigh, 0i32) })
                               },
                               else() { push(distanceLengths, 0i32) })
                            assign(previousLength, 0i32)
                            increment(position)
                            increment(repeatIndex)
                          })
                        },
                        else() { return(1i32) })
                   })
              })
         })
    })

    if(not_equal(plus(count(literalLengthsLow), count(literalLengthsHigh)), literalCount),
       then() { return(1i32) },
       else() { })
    if(not_equal(count(distanceLengths), distanceCount),
       then() { return(1i32) },
       else() { })
    if(or(or(less_equal(pngHuffmanMaxBits(literalLengthsLow), 0i32), less_equal(pngHuffmanMaxBits(literalLengthsHigh), 0i32)),
          equal(literalLengthsHigh[0i32], 0i32)),
       then() { return(1i32) },
       else() { })
    return(0i32)
  }

  [return<i32>]
