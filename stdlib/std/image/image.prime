         then() { return(1i32) },
         else() { })
      [mut] index{0i32}
      [mut] component{0i32}
      if(equal(formatByte, 51i32),
         then() {
           while(less_than(index, pixelCount), do() {
             status = ppmReadAsciiInt(file, hasPending, pendingByte, component)
             if(or(not_equal(status, 0i32), or(less_than(component, 0i32), greater_than(component, 255i32))),
                then() {
                  resetReadOutputs(width, height, pixels)
                  return(1i32)
                },
                else() { })
             /std/collections/vector/push(pixels, component)
             increment(index)
           })
         },
         else() {
           status = ppmReadBinaryRasterLead(file, hasPending, pendingByte, component)
           if(not_equal(status, 0i32),
              then() { return(1i32) },
              else() { })
           /std/collections/vector/push(pixels, component)
           index = 1i32
           while(less_than(index, pixelCount), do() {
             status = ppmReadByteStatus(file, component)
             if(not_equal(status, 0i32),
                then() {
                  resetReadOutputs(width, height, pixels)
                  return(1i32)
                },
                else() { })
             /std/collections/vector/push(pixels, component)
             increment(index)
           })
         })

      width = parsedWidth
      height = parsedHeight
      return(0i32)
    }

    [public return<Result<ImageError>> effects(file_read, heap_alloc)]
    read([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      resetReadOutputs(width, height, pixels)
      status{readImpl(width, height, pixels, path)}
      if(not_equal(status, 0i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(invalidOperation())
         },
         else() { })
      return(Result.ok())
    }

    [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
    writeImpl([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      if(not(ppmWriteInputValid(width, height, pixels)),
         then() { return(1i32) },
         else() { })

      file{File<Write>(path)?}
      [mut] status{ppmWriteHeader(file, width, height)}
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })

      pixelCount{count(pixels)}
      [mut] index{0i32}
      while(less_than(index, pixelCount), do() {
        status = ppmWriteComponent(file, pixels[index])
        if(not_equal(status, 0i32),
           then() { return(1i32) },
           else() { })
        increment(index)
      })
      return(0i32)
    }

    [public return<Result<ImageError>> effects(file_write)]
    write([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      status{writeImpl(path, width, height, pixels)}
      if(not_equal(status, 0i32),
         then() { return(invalidOperation()) },
         else() { })
      return(Result.ok())
    }
  }

  namespace png {
    [effects(file_read, heap_alloc), return<int> on_error<FileError, /std/image/ignoreFileError>]
    readImpl([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      file{File<Read>(path)?}
      signatureStatus{pngValidateSignature(file)}
      if(not_equal(signatureStatus, 0i32),
         then() { return(1i32) },
         else() { })

      [mut] sawIhdr{0i32}
      [mut] sawIdat{0i32}
      [mut] sawPlte{0i32}
      [mut] sawPostIdatChunk{0i32}
      [mut] parsedWidth{0i32}
      [mut] parsedHeight{0i32}
      [mut] bitDepth{0i32}
      [mut] colorType{0i32}
      [mut] interlace{0i32}
      [mut] idatBytes{vector<i32>()}
      [mut] plteBytes{vector<i32>()}
      [mut] rawBytes{vector<i32>()}
      while(true, do() {
        [mut] chunkLength{0i32}
        lengthStatus{pngReadU32Be(file, chunkLength)}
        if(or(not_equal(lengthStatus, 0i32), less_than(chunkLength, 0i32)),
           then() { return(1i32) },
           else() { })

        [mut] typeA{0i32}
        [mut] typeB{0i32}
        [mut] typeC{0i32}
        [mut] typeD{0i32}
        typeStatus{pngReadChunkType(file, typeA, typeB, typeC, typeD)}
        if(not_equal(typeStatus, 0i32),
           then() { return(1i32) },
           else() { })

        if(equal(sawIhdr, 0i32),
           then() {
             if(or(not(pngChunkIsIhdr(typeA, typeB, typeC, typeD)), not_equal(chunkLength, 13i32)),
                then() { return(1i32) },
                else() { })
             sawIhdr = 1i32
             ihdrStatus{pngReadIhdr(file, parsedWidth, parsedHeight, bitDepth, colorType, interlace)}
             if(not_equal(ihdrStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [mut] ihdrCrcA{0i32}
             [mut] ihdrCrcB{0i32}
             [mut] ihdrCrcC{0i32}
             [mut] ihdrCrcD{0i32}
             ihdrCrcStatus{pngReadChunkType(file, ihdrCrcA, ihdrCrcB, ihdrCrcC, ihdrCrcD)}
             if(not_equal(ihdrCrcStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [mut] ihdrBytes{vector<i32>()}
             pngAppendU32Be(parsedWidth, ihdrBytes)
             pngAppendU32Be(parsedHeight, ihdrBytes)
             /std/collections/vector/push(ihdrBytes, bitDepth)
             /std/collections/vector/push(ihdrBytes, colorType)
             /std/collections/vector/push(ihdrBytes, 0i32)
             /std/collections/vector/push(ihdrBytes, 0i32)
             /std/collections/vector/push(ihdrBytes, interlace)
             if(not(pngChunkCrcMatches(typeA, typeB, typeC, typeD, ihdrBytes, ihdrCrcA, ihdrCrcB, ihdrCrcC, ihdrCrcD)),
                then() { return(1i32) },
                else() { })
           },
           else() {
             if(pngChunkIsIhdr(typeA, typeB, typeC, typeD),
                then() { return(1i32) },
                else() { })
             if(pngChunkIsPlte(typeA, typeB, typeC, typeD),
                then() {
                  if(or(not_equal(sawPlte, 0i32), not_equal(sawIdat, 0i32)),
                     then() { return(1i32) },
                     else() { })
                  sawPlte = 1i32
                },
                else() { })
             if(and(not_equal(sawPostIdatChunk, 0i32), pngChunkIsIdat(typeA, typeB, typeC, typeD)),
                then() { return(1i32) },
                else() { })
             if(and(not_equal(sawIdat, 0i32),
                    and(not(pngChunkIsIdat(typeA, typeB, typeC, typeD)),
                        and(not(pngChunkIsIend(typeA, typeB, typeC, typeD)),
                            not(pngChunkIsAncillary(typeA))))),
                then() { return(1i32) },
                else() { })
             [mut] chunkBytes{vector<i32>()}
             payloadStatus{pngAppendBytes(file, chunkLength, chunkBytes)}
             if(not_equal(payloadStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [mut] crcA{0i32}
             [mut] crcB{0i32}
             [mut] crcC{0i32}
             [mut] crcD{0i32}
             crcStatus{pngReadChunkType(file, crcA, crcB, crcC, crcD)}
             if(not_equal(crcStatus, 0i32),
                then() { return(1i32) },
                else() { })
             if(and(not(pngChunkIsAncillary(typeA)),
                    not(pngChunkCrcMatches(typeA, typeB, typeC, typeD, chunkBytes, crcA, crcB, crcC, crcD))),
                then() { return(1i32) },
                else() { })
             if(pngChunkIsPlte(typeA, typeB, typeC, typeD),
                then() {
                  if(or(or(equal(count(chunkBytes), 0i32), not_equal(pngMod(count(chunkBytes), 3i32), 0i32)),
                        greater_than(count(chunkBytes), 768i32)),
                     then() { return(1i32) },
                     else() { })
                  /std/collections/vector/clear(plteBytes)
                  pngAppendVectorBytes(chunkBytes, plteBytes)
                },
                else() { })
             if(and(not_equal(sawIdat, 0i32), not(pngChunkIsIdat(typeA, typeB, typeC, typeD))),
                then() { sawPostIdatChunk = 1i32 },
                else() { })
             if(pngChunkIsIdat(typeA, typeB, typeC, typeD),
                then() {
                  sawIdat = 1i32
                  pngAppendVectorBytes(chunkBytes, idatBytes)
                },
                else() { })
             if(pngChunkIsIend(typeA, typeB, typeC, typeD),
                then() {
                  if(or(not_equal(chunkLength, 0i32), equal(sawIdat, 0i32)),
                     then() { return(1i32) },
                     else() {
                       inflateStatus{pngInflateDeflateBlocks(idatBytes, rawBytes)}
                       if(equal(inflateStatus, 1i32),
                          then() { return(1i32) },
                          else() { })
                       if(equal(inflateStatus, 2i32),
                          then() { return(2i32) },
                          else() { })

                       if(and(equal(colorType, 3i32), equal(count(plteBytes), 0i32)),
                          then() { return(1i32) },
                          else() { })

                       decodeStatus{pngDecodeScanlines(rawBytes, parsedWidth, parsedHeight, bitDepth, colorType, interlace, plteBytes, pixels)}
                       if(equal(decodeStatus, 1i32),
                          then() {
                            resetReadOutputs(width, height, pixels)
                            return(1i32)
                          },
                          else() { })
                       if(equal(decodeStatus, 2i32),
                          then() {
                            resetReadOutputs(width, height, pixels)
                            return(2i32)
                          },
                          else() { })

                       width = parsedWidth
                       height = parsedHeight
                       return(0i32)
                     })
                },
                else() { })
           })
      })
      return(1i32)
    }

    [public return<Result<ImageError>> effects(file_read, heap_alloc)]
    read([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      resetReadOutputs(width, height, pixels)
      status{readImpl(width, height, pixels, path)}
      if(equal(status, 1i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(invalidOperation())
         },
         else() { })
      if(equal(status, 2i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(unsupported_read())
         },
         else() { })
      return(Result.ok())
    }

    [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
    writeImpl([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      if(not(ppmWriteInputValid(width, height, pixels)),
         then() { return(1i32) },
         else() { })
      [mut] rawByteCount{0i32}
      [mut] payloadLength{0i32}
      if(not(pngWriteSizingValid(width, height, rawByteCount, payloadLength)),
         then() { return(1i32) },
         else() { })

      file{File<Write>(path)?}
      signatureStatus{pngWriteSignature(file)}
      if(not_equal(signatureStatus, 0i32),
         then() { return(signatureStatus) },
         else() { })
      ihdrStatus{pngWriteIhdrChunk(file, width, height)}
      if(not_equal(ihdrStatus, 0i32),
         then() { return(ihdrStatus) },
         else() { })
      idatStatus{pngWriteIdatChunk(file, width, height, pixels, rawByteCount, payloadLength)}
      if(not_equal(idatStatus, 0i32),
         then() { return(idatStatus) },
         else() { })
      return(pngWriteIendChunk(file))
    }

    [public return<Result<ImageError>> effects(file_write)]
    write([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      status{writeImpl(path, width, height, pixels)}
      if(not_equal(status, 0i32),
         then() { return(invalidOperation()) },
         else() { })
      return(Result.ok())
    }
  }
}
}
