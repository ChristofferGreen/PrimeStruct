            else() { })
       },
       else() { })

    [i32 mut] offset{0i32}
    if(equal(interlace, 0i32),
       then() {
         [i32] rowStatus{pngDecodeRows(rawBytes, offset, width, height, bitDepth, colorType, paletteBytes, pixels)}
         if(not_equal(rowStatus, 0i32),
            then() {
              /std/collections/vector/clear(pixels)
              return(rowStatus)
            },
            else() { })
       },
	       else() {
	         if(not_equal(interlace, 1i32),
	            then() { return(2i32) },
	            else() { })
	         [i32] initStatus{pngInitRgbPixels(width, height, pixels)}
	         if(not_equal(initStatus, 0i32),
	            then() {
	              /std/collections/vector/clear(pixels)
	              return(1i32)
	            },
	            else() { })
	         [vector<i32> mut] passPixels{vector<i32>()}
         [i32 mut] passIndex{0i32}
         while(less_than(passIndex, 7i32), do() {
           [i32] passStartX{pngAdam7PassStartX(passIndex)}
           [i32] passStartY{pngAdam7PassStartY(passIndex)}
           [i32] passStepX{pngAdam7PassStepX(passIndex)}
           [i32] passStepY{pngAdam7PassStepY(passIndex)}
           [i32] passWidth{pngAdam7PassSpan(width, passStartX, passStepX)}
           [i32] passHeight{pngAdam7PassSpan(height, passStartY, passStepY)}
           if(and(greater_than(passWidth, 0i32), greater_than(passHeight, 0i32)),
              then() {
                [i32] passStatus{pngDecodeRows(rawBytes, offset, passWidth, passHeight, bitDepth, colorType, paletteBytes, passPixels)}
                if(not_equal(passStatus, 0i32),
                   then() {
                     /std/collections/vector/clear(pixels)
                     return(passStatus)
                   },
                   else() { })
                [i32 mut] passRow{0i32}
                while(less_than(passRow, passHeight), do() {
                  [i32 mut] passColumn{0i32}
                  while(less_than(passColumn, passWidth), do() {
                    [i32] imageX{plus(passStartX, multiply(passColumn, passStepX))}
                    [i32] imageY{plus(passStartY, multiply(passRow, passStepY))}
                    [i32] sourceOffset{multiply(plus(multiply(passRow, passWidth), passColumn), 3i32)}
                    [i32] targetOffset{multiply(plus(multiply(imageY, width), imageX), 3i32)}
                    assign(pixels[targetOffset], passPixels[sourceOffset])
                    assign(pixels[plus(targetOffset, 1i32)], passPixels[plus(sourceOffset, 1i32)])
                    assign(pixels[plus(targetOffset, 2i32)], passPixels[plus(sourceOffset, 2i32)])
                    increment(passColumn)
                  })
                  increment(passRow)
                })
              },
              else() { })
           increment(passIndex)
         })
       })
    if(not_equal(offset, count(rawBytes)),
       then() {
         /std/collections/vector/clear(pixels)
         return(1i32)
       },
       else() { })
    return(0i32)
  }

  namespace ppm {
    [effects(file_read, heap_alloc), return<int> on_error<FileError, /std/image/ignoreFileError>]
    readImpl([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      [File<Read>] file{File<Read>(path)?}
      [i32 mut] hasPending{0i32}
      [i32 mut] pendingByte{0i32}
      [i32 mut] byte{0i32}
      [i32 mut] formatByte{0i32}
      [i32 mut] status{ppmNextByte(file, hasPending, pendingByte, byte)}
      if(or(not_equal(status, 0i32), not_equal(byte, 80i32)),
         then() { return(1i32) },
         else() { })

      status = ppmNextByte(file, hasPending, pendingByte, byte)
      if(or(not_equal(status, 0i32), and(not_equal(byte, 51i32), not_equal(byte, 54i32))),
         then() { return(1i32) },
         else() { formatByte = byte })
      status = ppmNextByte(file, hasPending, pendingByte, byte)
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      if(or(ppmIsWhitespace(byte), equal(byte, 35i32)),
         then() {
           hasPending = 1i32
           pendingByte = byte
         },
         else() { return(1i32) })

      [i32 mut] parsedWidth{0i32}
      [i32 mut] parsedHeight{0i32}
      [i32 mut] maxValue{0i32}
      status = ppmReadAsciiInt(file, hasPending, pendingByte, parsedWidth)
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      status = ppmReadAsciiInt(file, hasPending, pendingByte, parsedHeight)
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      status = ppmReadAsciiInt(file, hasPending, pendingByte, maxValue)
      if(or(or(not_equal(status, 0i32), not_equal(maxValue, 255i32)),
            or(less_equal(parsedWidth, 0i32), less_equal(parsedHeight, 0i32))),
         then() { return(1i32) },
         else() { })

      [i32 mut] pixelCount{0i32}
      if(not(imageRgbWritePixelCount(parsedWidth, parsedHeight, pixelCount)),
         then() { return(1i32) },
         else() { })
      [i32 mut] index{0i32}
      [i32 mut] component{0i32}
      if(equal(formatByte, 51i32),
         then() {
           while(less_than(index, pixelCount), do() {
             status = ppmReadAsciiInt(file, hasPending, pendingByte, component)
             if(or(not_equal(status, 0i32), or(less_than(component, 0i32), greater_than(component, 255i32))),
                then() {
                  resetReadOutputs(width, height, pixels)
                  return(1i32)
                },
                else() { })
             /std/collections/vector/push(pixels, component)
             increment(index)
           })
         },
         else() {
           status = ppmReadBinaryRasterLead(file, hasPending, pendingByte, component)
           if(not_equal(status, 0i32),
              then() { return(1i32) },
              else() { })
           /std/collections/vector/push(pixels, component)
           index = 1i32
           while(less_than(index, pixelCount), do() {
             status = ppmReadByteStatus(file, component)
             if(not_equal(status, 0i32),
                then() {
                  resetReadOutputs(width, height, pixels)
                  return(1i32)
                },
                else() { })
             /std/collections/vector/push(pixels, component)
             increment(index)
           })
         })

      width = parsedWidth
      height = parsedHeight
      return(0i32)
    }

	    [public return<Result<ImageError>> effects(file_read, heap_alloc)]
	    read([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
	      resetReadOutputs(width, height, pixels)
	      [i32] status{readImpl(width, height, pixels, path)}
      if(not_equal(status, 0i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(invalidOperation())
         },
         else() { })
      return(Result.ok())
    }

    [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
    writeImpl([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      if(not(ppmWriteInputValid(width, height, pixels)),
         then() { return(1i32) },
         else() { })

      [File<Write>] file{File<Write>(path)?}
      [i32 mut] status{ppmWriteHeader(file, width, height)}
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })

      [i32] pixelCount{count(pixels)}
      [i32 mut] index{0i32}
      while(less_than(index, pixelCount), do() {
        status = ppmWriteComponent(file, pixels[index])
        if(not_equal(status, 0i32),
           then() { return(1i32) },
           else() { })
        increment(index)
      })
      return(0i32)
    }

    [public return<Result<ImageError>> effects(file_write)]
    write([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      [i32] status{writeImpl(path, width, height, pixels)}
      if(not_equal(status, 0i32),
         then() { return(invalidOperation()) },
         else() { })
      return(Result.ok())
    }
  }

  namespace png {
    [effects(file_read, heap_alloc), return<int> on_error<FileError, /std/image/ignoreFileError>]
    readImpl([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      [File<Read>] file{File<Read>(path)?}
      [i32] signatureStatus{pngValidateSignature(file)}
      if(not_equal(signatureStatus, 0i32),
         then() { return(1i32) },
         else() { })

      [i32 mut] sawIhdr{0i32}
      [i32 mut] sawIdat{0i32}
      [i32 mut] sawPlte{0i32}
      [i32 mut] sawPostIdatChunk{0i32}
      [i32 mut] parsedWidth{0i32}
      [i32 mut] parsedHeight{0i32}
      [i32 mut] bitDepth{0i32}
      [i32 mut] colorType{0i32}
      [i32 mut] interlace{0i32}
      [vector<i32> mut] idatBytes{vector<i32>()}
      [vector<i32> mut] plteBytes{vector<i32>()}
      [vector<i32> mut] rawBytes{vector<i32>()}
      while(true, do() {
        [i32 mut] chunkLength{0i32}
        [i32] lengthStatus{pngReadU32Be(file, chunkLength)}
        if(or(not_equal(lengthStatus, 0i32), less_than(chunkLength, 0i32)),
           then() { return(1i32) },
           else() { })

        [i32 mut] typeA{0i32}
        [i32 mut] typeB{0i32}
        [i32 mut] typeC{0i32}
        [i32 mut] typeD{0i32}
        [i32] typeStatus{pngReadChunkType(file, typeA, typeB, typeC, typeD)}
        if(not_equal(typeStatus, 0i32),
           then() { return(1i32) },
           else() { })

        if(equal(sawIhdr, 0i32),
           then() {
             if(or(not(pngChunkIsIhdr(typeA, typeB, typeC, typeD)), not_equal(chunkLength, 13i32)),
                then() { return(1i32) },
                else() { })
             assign(sawIhdr, 1i32)
             [i32] ihdrStatus{pngReadIhdr(file, parsedWidth, parsedHeight, bitDepth, colorType, interlace)}
             if(not_equal(ihdrStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [i32 mut] ihdrCrcA{0i32}
             [i32 mut] ihdrCrcB{0i32}
             [i32 mut] ihdrCrcC{0i32}
             [i32 mut] ihdrCrcD{0i32}
             [i32] ihdrCrcStatus{pngReadChunkType(file, ihdrCrcA, ihdrCrcB, ihdrCrcC, ihdrCrcD)}
             if(not_equal(ihdrCrcStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [vector<i32> mut] ihdrBytes{vector<i32>()}
             pngAppendU32Be(parsedWidth, ihdrBytes)
             pngAppendU32Be(parsedHeight, ihdrBytes)
             /std/collections/vector/push(ihdrBytes, bitDepth)
             /std/collections/vector/push(ihdrBytes, colorType)
             /std/collections/vector/push(ihdrBytes, 0i32)
             /std/collections/vector/push(ihdrBytes, 0i32)
             /std/collections/vector/push(ihdrBytes, interlace)
             if(not(pngChunkCrcMatches(typeA, typeB, typeC, typeD, ihdrBytes, ihdrCrcA, ihdrCrcB, ihdrCrcC, ihdrCrcD)),
                then() { return(1i32) },
                else() { })
           },
           else() {
             if(pngChunkIsIhdr(typeA, typeB, typeC, typeD),
                then() { return(1i32) },
                else() { })
             if(pngChunkIsPlte(typeA, typeB, typeC, typeD),
                then() {
                  if(or(not_equal(sawPlte, 0i32), not_equal(sawIdat, 0i32)),
                     then() { return(1i32) },
                     else() { })
                  assign(sawPlte, 1i32)
                },
                else() { })
             if(and(not_equal(sawPostIdatChunk, 0i32), pngChunkIsIdat(typeA, typeB, typeC, typeD)),
                then() { return(1i32) },
                else() { })
             if(and(not_equal(sawIdat, 0i32),
                    and(not(pngChunkIsIdat(typeA, typeB, typeC, typeD)),
                        and(not(pngChunkIsIend(typeA, typeB, typeC, typeD)),
                            not(pngChunkIsAncillary(typeA))))),
                then() { return(1i32) },
                else() { })
             [vector<i32> mut] chunkBytes{vector<i32>()}
             [i32] payloadStatus{pngAppendBytes(file, chunkLength, chunkBytes)}
             if(not_equal(payloadStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [i32 mut] crcA{0i32}
             [i32 mut] crcB{0i32}
             [i32 mut] crcC{0i32}
             [i32 mut] crcD{0i32}
             [i32] crcStatus{pngReadChunkType(file, crcA, crcB, crcC, crcD)}
             if(not_equal(crcStatus, 0i32),
                then() { return(1i32) },
                else() { })
             if(and(not(pngChunkIsAncillary(typeA)),
                    not(pngChunkCrcMatches(typeA, typeB, typeC, typeD, chunkBytes, crcA, crcB, crcC, crcD))),
                then() { return(1i32) },
                else() { })
             if(pngChunkIsPlte(typeA, typeB, typeC, typeD),
                then() {
                  if(or(or(equal(count(chunkBytes), 0i32), not_equal(pngMod(count(chunkBytes), 3i32), 0i32)),
                        greater_than(count(chunkBytes), 768i32)),
                     then() { return(1i32) },
                     else() { })
                  /std/collections/vector/clear(plteBytes)
                  pngAppendVectorBytes(chunkBytes, plteBytes)
                },
                else() { })
             if(and(not_equal(sawIdat, 0i32), not(pngChunkIsIdat(typeA, typeB, typeC, typeD))),
                then() { assign(sawPostIdatChunk, 1i32) },
                else() { })
             if(pngChunkIsIdat(typeA, typeB, typeC, typeD),
                then() {
                  assign(sawIdat, 1i32)
                  pngAppendVectorBytes(chunkBytes, idatBytes)
                },
                else() { })
             if(pngChunkIsIend(typeA, typeB, typeC, typeD),
                then() {
                  if(or(not_equal(chunkLength, 0i32), equal(sawIdat, 0i32)),
                     then() { return(1i32) },
                     else() {
                       [i32] inflateStatus{pngInflateDeflateBlocks(idatBytes, rawBytes)}
                       if(equal(inflateStatus, 1i32),
                          then() { return(1i32) },
                          else() { })
                       if(equal(inflateStatus, 2i32),
                          then() { return(2i32) },
                          else() { })

                       if(and(equal(colorType, 3i32), equal(count(plteBytes), 0i32)),
                          then() { return(1i32) },
                          else() { })

                       [i32] decodeStatus{pngDecodeScanlines(rawBytes, parsedWidth, parsedHeight, bitDepth, colorType, interlace, plteBytes, pixels)}
                       if(equal(decodeStatus, 1i32),
                          then() {
                            resetReadOutputs(width, height, pixels)
                            return(1i32)
                          },
                          else() { })
                       if(equal(decodeStatus, 2i32),
                          then() {
                            resetReadOutputs(width, height, pixels)
                            return(2i32)
                          },
                          else() { })

                       assign(width, parsedWidth)
                       assign(height, parsedHeight)
                       return(0i32)
                     })
                },
                else() { })
           })
      })
      return(1i32)
    }

    [public return<Result<ImageError>> effects(file_read, heap_alloc)]
    read([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      resetReadOutputs(width, height, pixels)
      [i32] status{readImpl(width, height, pixels, path)}
      if(equal(status, 1i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(invalidOperation())
         },
         else() { })
      if(equal(status, 2i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(unsupported_read())
         },
         else() { })
      return(Result.ok())
    }

    [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
    writeImpl([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      if(not(ppmWriteInputValid(width, height, pixels)),
         then() { return(1i32) },
         else() { })
      [i32 mut] rawByteCount{0i32}
      [i32 mut] payloadLength{0i32}
      if(not(pngWriteSizingValid(width, height, rawByteCount, payloadLength)),
         then() { return(1i32) },
         else() { })

      [File<Write>] file{File<Write>(path)?}
      [i32] signatureStatus{pngWriteSignature(file)}
      if(not_equal(signatureStatus, 0i32),
         then() { return(signatureStatus) },
         else() { })
      [i32] ihdrStatus{pngWriteIhdrChunk(file, width, height)}
      if(not_equal(ihdrStatus, 0i32),
         then() { return(ihdrStatus) },
         else() { })
      [i32] idatStatus{pngWriteIdatChunk(file, width, height, pixels, rawByteCount, payloadLength)}
      if(not_equal(idatStatus, 0i32),
         then() { return(idatStatus) },
         else() { })
      return(pngWriteIendChunk(file))
    }

    [public return<Result<ImageError>> effects(file_write)]
    write([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      [i32] status{writeImpl(path, width, height, pixels)}
      if(not_equal(status, 0i32),
         then() { return(invalidOperation()) },
         else() { })
      return(Result.ok())
    }
  }
}
