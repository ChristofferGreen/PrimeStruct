  [effects(heap_alloc), return<int>]
  pngReadDynamicHuffmanLengths([vector<i32>] compressed, [i32 mut] byteIndex, [i32 mut] bitIndex,
                               [i32] codeLengthCodeCount, [i32] literalCount, [i32] distanceCount,
                               [vector<i32> mut] literalLengthsLow, [vector<i32> mut] literalLengthsHigh,
