         then() { inflateStatus = pngInflateStoredBlock(compressed, byteIndex, bitIndex, output) },
         else() {
           if(equal(blockType, 1i32),
              then() { inflateStatus = pngInflateFixedHuffmanBlock(compressed, byteIndex, bitIndex, output) },
              else() {
                if(equal(blockType, 2i32),
                   then() { inflateStatus = pngInflateDynamicHuffmanBlock(compressed, byteIndex, bitIndex, output) },
                   else() { return(1i32) })
              })
         })
      if(not_equal(inflateStatus, 0i32),
         then() { return(inflateStatus) },
         else() { })

      if(equal(isFinal, 1i32),
         then() {
           if(not_equal(bitIndex, 0i32),
              then() {
                bitIndex = 0i32
                byteIndex = byteIndex + 1i32
