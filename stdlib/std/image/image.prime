  [return<int>]
  pngHuffmanDecodeSplitLiteralSymbol([vector<i32>] bytes, [i32 mut] byteIndex, [i32 mut] bitIndex,
                                     [vector<i32>] literalLengthsLow, [vector<i32>] literalLengthsHigh,
                                     [i32] maxBits, [i32 mut] symbolOut) {
    assign(symbolOut, 0i32)
