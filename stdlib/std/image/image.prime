                       if(less_than(position, 256i32),
                          then() { /std/collections/vector/push(literalLengthsLow, previousLength) },
                          else() { /std/collections/vector/push(literalLengthsHigh, previousLength) })
                     },
                     else() { /std/collections/vector/push(distanceLengths, previousLength) })
                  increment(position)
                  increment(repeatIndex)
                })
              },
              else() {
                if(equal(symbol, 17i32),
                   then() {
                     [mut] repeatExtra{0i32}
                     repeatStatus{pngReadBits(compressed, byteIndex, bitIndex, 3i32, repeatExtra)}
                     if(not_equal(repeatStatus, 0i32),
                        then() { return(1i32) },
                        else() { })
                     repeatCount{3i32 + repeatExtra}
                     if(greater_than(position + repeatCount, totalCodeCount),
                        then() { return(1i32) },
                        else() { })
                     [mut] repeatIndex{0i32}
                     while(less_than(repeatIndex, repeatCount), do() {
                       if(less_than(position, literalCount),
                          then() {
                            if(less_than(position, 256i32),
                               then() { /std/collections/vector/push(literalLengthsLow, 0i32) },
                               else() { /std/collections/vector/push(literalLengthsHigh, 0i32) })
                          },
                          else() { /std/collections/vector/push(distanceLengths, 0i32) })
                       previousLength = 0i32
