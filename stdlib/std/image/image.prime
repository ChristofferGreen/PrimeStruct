  [effects(heap_alloc), return<int>]
  pngDecodeScanlines([vector<i32>] rawBytes, [i32] width, [i32] height, [i32] bitDepth, [i32] colorType,
                     [i32] interlace, [vector<i32>] paletteBytes, [vector<i32> mut] pixels) {
    /std/collections/vector/clear(pixels)
    if(and(not_equal(colorType, 0i32),
           and(not_equal(colorType, 2i32),
               and(not_equal(colorType, 3i32), and(not_equal(colorType, 4i32), not_equal(colorType, 6i32))))),
       then() { return(2i32) },
       else() { })
    if(not(pngDecodeBitDepthSupported(bitDepth, colorType)),
       then() { return(2i32) },
       else() { })
    if(equal(colorType, 3i32),
       then() {
         if(or(or(equal(count(paletteBytes), 0i32), not_equal(pngMod(count(paletteBytes), 3i32), 0i32)),
               greater_than(count(paletteBytes), 768i32)),
            then() { return(1i32) },
            else() { })
       },
       else() { })

    [mut] offset{0i32}
    if(equal(interlace, 0i32),
       then() {
         rowStatus{pngDecodeRows(rawBytes, offset, width, height, bitDepth, colorType, paletteBytes, pixels)}
         if(not_equal(rowStatus, 0i32),
            then() {
              /std/collections/vector/clear(pixels)
              return(rowStatus)
            },
            else() { })
       },
	       else() {
	         if(not_equal(interlace, 1i32),
	            then() { return(2i32) },
	            else() { })
	         initStatus{pngInitRgbPixels(width, height, pixels)}
	         if(not_equal(initStatus, 0i32),
	            then() {
	              /std/collections/vector/clear(pixels)
	              return(1i32)
	            },
	            else() { })
	         [mut] passPixels{vector<i32>()}
         [mut] passIndex{0i32}
         while(less_than(passIndex, 7i32), do() {
           passStartX{pngAdam7PassStartX(passIndex)}
           passStartY{pngAdam7PassStartY(passIndex)}
           passStepX{pngAdam7PassStepX(passIndex)}
           passStepY{pngAdam7PassStepY(passIndex)}
           passWidth{pngAdam7PassSpan(width, passStartX, passStepX)}
           passHeight{pngAdam7PassSpan(height, passStartY, passStepY)}
           if(and(greater_than(passWidth, 0i32), greater_than(passHeight, 0i32)),
              then() {
                passStatus{pngDecodeRows(rawBytes, offset, passWidth, passHeight, bitDepth, colorType, paletteBytes, passPixels)}
                if(not_equal(passStatus, 0i32),
                   then() {
                     /std/collections/vector/clear(pixels)
                     return(passStatus)
                   },
                   else() { })
                [mut] passRow{0i32}
                while(less_than(passRow, passHeight), do() {
                  [mut] passColumn{0i32}
                  while(less_than(passColumn, passWidth), do() {
                    imageX{passStartX + multiply(passColumn, passStepX)}
                    imageY{passStartY + multiply(passRow, passStepY)}
                    sourceOffset{multiply(multiply(passRow, passWidth) + passColumn, 3i32)}
                    targetOffset{multiply(multiply(imageY, width) + imageX, 3i32)}
                    pixels[targetOffset] = passPixels[sourceOffset]
                    pixels[targetOffset + 1i32] = passPixels[sourceOffset + 1i32]
                    pixels[targetOffset + 2i32] = passPixels[sourceOffset + 2i32]
                    increment(passColumn)
                  })
                  increment(passRow)
                })
              },
              else() { })
           increment(passIndex)
         })
       })
    if(not_equal(offset, count(rawBytes)),
       then() {
         /std/collections/vector/clear(pixels)
         return(1i32)
       },
       else() { })
    return(0i32)
  }

  namespace ppm {
    [effects(file_read, heap_alloc), return<int> on_error<FileError, /std/image/ignoreFileError>]
    readImpl([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      file{File<Read>(path)?}
      [mut] hasPending{0i32}
      [mut] pendingByte{0i32}
      [mut] byte{0i32}
      [mut] formatByte{0i32}
      [mut] status{ppmNextByte(file, hasPending, pendingByte, byte)}
      if(or(not_equal(status, 0i32), not_equal(byte, 80i32)),
         then() { return(1i32) },
         else() { })

      status = ppmNextByte(file, hasPending, pendingByte, byte)
      if(or(not_equal(status, 0i32), and(not_equal(byte, 51i32), not_equal(byte, 54i32))),
         then() { return(1i32) },
         else() { formatByte = byte })
      status = ppmNextByte(file, hasPending, pendingByte, byte)
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      if(or(ppmIsWhitespace(byte), equal(byte, 35i32)),
         then() {
           hasPending = 1i32
           pendingByte = byte
