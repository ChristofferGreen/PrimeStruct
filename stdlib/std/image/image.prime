  [effects(heap_alloc), return<int>]
  pngInflateDeflateBlocks([vector<i32>] compressed, [vector<i32> mut] output) {
    /std/collections/vector/clear(output)
    compressedCount{count(compressed)}
    if(less_than(compressedCount, 7i32),
       then() { return(1i32) },
       else() { })

    if(not(pngZlibHeaderValid(compressed[0i32], compressed[1i32])),
       then() { return(1i32) },
       else() { })

    [mut] byteIndex{2i32}
    [mut] bitIndex{0i32}
    while(true, do() {
      [mut] isFinal{0i32}
      finalStatus{pngReadBits(compressed, byteIndex, bitIndex, 1i32, isFinal)}
      if(not_equal(finalStatus, 0i32),
         then() { return(1i32) },
         else() { })

