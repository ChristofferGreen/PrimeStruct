  [return<int>]
  pngDecodeFixedLiteralSymbol([vector<i32>] bytes, [i32 mut] byteIndex, [i32 mut] bitIndex, [i32 mut] symbolOut) {
    assign(symbolOut, 0i32)
    [i32 mut] code{0i32}
    [i32 mut] factor{1i32}
    [i32 mut] bitsRead{0i32}
    while(less_than(bitsRead, 9i32), do() {
      [i32 mut] bit{0i32}
      [i32] bitStatus{pngReadBits(bytes, byteIndex, bitIndex, 1i32, bit)}
      if(not_equal(bitStatus, 0i32),
         then() { return(1i32) },
         else() { })
      assign(code, plus(code, multiply(bit, factor)))
      assign(factor, multiply(factor, 2i32))
      increment(bitsRead)

      if(equal(bitsRead, 7i32),
         then() {
           [i32 mut] symbol{256i32}
           while(less_than(symbol, 280i32), do() {
             if(equal(pngReverseBits(minus(symbol, 256i32), 7i32), code),
                then() {
                  assign(symbolOut, symbol)
                  return(0i32)
                },
                else() { })
             increment(symbol)
           })
         },
         else() { })

      if(equal(bitsRead, 8i32),
         then() {
           [i32 mut] symbol{0i32}
           while(less_than(symbol, 144i32), do() {
             if(equal(pngReverseBits(plus(48i32, symbol), 8i32), code),
                then() {
                  assign(symbolOut, symbol)
                  return(0i32)
                },
                else() { })
             increment(symbol)
           })
           assign(symbol, 280i32)
           while(less_than(symbol, 288i32), do() {
             if(equal(pngReverseBits(plus(192i32, minus(symbol, 280i32)), 8i32), code),
                then() {
                  assign(symbolOut, symbol)
                  return(0i32)
                },
                else() { })
             increment(symbol)
           })
         },
         else() { })

      if(equal(bitsRead, 9i32),
         then() {
           [i32 mut] symbol{144i32}
           while(less_than(symbol, 256i32), do() {
             if(equal(pngReverseBits(plus(400i32, minus(symbol, 144i32)), 9i32), code),
                then() {
                  assign(symbolOut, symbol)
                  return(0i32)
                },
                else() { })
             increment(symbol)
           })
         },
         else() { })
    })
    return(1i32)
  }

  [return<int>]
  pngDecodeFixedDistanceSymbol([vector<i32>] bytes, [i32 mut] byteIndex, [i32 mut] bitIndex, [i32 mut] symbolOut) {
    assign(symbolOut, 0i32)
    [i32 mut] code{0i32}
    [i32 mut] factor{1i32}
    [i32 mut] bitsRead{0i32}
    while(less_than(bitsRead, 5i32), do() {
      [i32 mut] bit{0i32}
      [i32] bitStatus{pngReadBits(bytes, byteIndex, bitIndex, 1i32, bit)}
      if(not_equal(bitStatus, 0i32),
         then() { return(1i32) },
         else() { })
      assign(code, plus(code, multiply(bit, factor)))
      assign(factor, multiply(factor, 2i32))
      increment(bitsRead)

      if(equal(bitsRead, 5i32),
         then() {
           [i32 mut] symbol{0i32}
           while(less_than(symbol, 32i32), do() {
             if(equal(pngReverseBits(symbol, 5i32), code),
                then() {
                  assign(symbolOut, symbol)
                  return(0i32)
                },
                else() { })
             increment(symbol)
           })
         },
         else() { })
    })
    return(1i32)
  }

  [effects(heap_alloc), return<int>]
  pngInflateFixedHuffmanBlock([vector<i32>] compressed, [i32 mut] byteIndex, [i32 mut] bitIndex,
                              [vector<i32> mut] output) {
    while(true, do() {
      [i32 mut] symbol{0i32}
      [i32] status{pngDecodeFixedLiteralSymbol(compressed, byteIndex, bitIndex, symbol)}
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      if(less_than(symbol, 256i32),
         then() { push(output, symbol) },
         else() {
           if(equal(symbol, 256i32),
              then() { return(0i32) },
              else() {
                [i32 mut] lengthBase{0i32}
                [i32 mut] lengthExtraBits{0i32}
                [i32] lengthInfoStatus{pngLengthInfo(symbol, lengthBase, lengthExtraBits)}
                if(not_equal(lengthInfoStatus, 0i32),
                   then() { return(1i32) },
                   else() { })

                [i32 mut] lengthExtraValue{0i32}
                if(greater_than(lengthExtraBits, 0i32),
                   then() {
                     [i32] lengthExtraStatus{pngReadBits(compressed, byteIndex, bitIndex, lengthExtraBits, lengthExtraValue)}
                     if(not_equal(lengthExtraStatus, 0i32),
                        then() { return(1i32) },
                        else() { })
                   },
                   else() { })
                [i32] matchLength{plus(lengthBase, lengthExtraValue)}

                [i32 mut] distanceSymbol{0i32}
                [i32] distanceStatus{pngDecodeFixedDistanceSymbol(compressed, byteIndex, bitIndex, distanceSymbol)}
                if(not_equal(distanceStatus, 0i32),
                   then() { return(1i32) },
                   else() { })

                [i32 mut] distanceBase{0i32}
                [i32 mut] distanceExtraBits{0i32}
                [i32] distanceInfoStatus{pngDistanceInfo(distanceSymbol, distanceBase, distanceExtraBits)}
                if(not_equal(distanceInfoStatus, 0i32),
                   then() { return(1i32) },
                   else() { })

                [i32 mut] distanceExtraValue{0i32}
                if(greater_than(distanceExtraBits, 0i32),
                   then() {
                     [i32] distanceExtraStatus{pngReadBits(compressed, byteIndex, bitIndex, distanceExtraBits, distanceExtraValue)}
                     if(not_equal(distanceExtraStatus, 0i32),
                        then() { return(1i32) },
                        else() { })
                   },
                   else() { })

                [i32] copyStatus{pngInflateCopyFromOutput(output, plus(distanceBase, distanceExtraValue), matchLength)}
                if(not_equal(copyStatus, 0i32),
                   then() { return(1i32) },
                   else() { })
              })
         })
    })
    return(1i32)
  }

  [effects(heap_alloc), return<int>]
  pngInflateDynamicHuffmanBlock([vector<i32>] compressed, [i32 mut] byteIndex, [i32 mut] bitIndex,
                                [vector<i32> mut] output) {
    [i32 mut] hlitBits{0i32}
    [i32] hlitStatus{pngReadBits(compressed, byteIndex, bitIndex, 5i32, hlitBits)}
    if(not_equal(hlitStatus, 0i32),
       then() { return(1i32) },
       else() { })
    [i32 mut] hdistBits{0i32}
    [i32] hdistStatus{pngReadBits(compressed, byteIndex, bitIndex, 5i32, hdistBits)}
    if(not_equal(hdistStatus, 0i32),
       then() { return(1i32) },
       else() { })
    [i32 mut] hclenBits{0i32}
    [i32] hclenStatus{pngReadBits(compressed, byteIndex, bitIndex, 4i32, hclenBits)}
    if(not_equal(hclenStatus, 0i32),
       then() { return(1i32) },
       else() { })

    [vector<i32> mut] literalLengthsLow{vector<i32>()}
    [vector<i32> mut] literalLengthsHigh{vector<i32>()}
    [vector<i32> mut] distanceLengths{vector<i32>()}
    [i32] lengthStatus{pngReadDynamicHuffmanLengths(compressed, byteIndex, bitIndex, plus(hclenBits, 4i32),
                                                    plus(hlitBits, 257i32), plus(hdistBits, 1i32), literalLengthsLow,
                                                    literalLengthsHigh, distanceLengths)}
    if(not_equal(lengthStatus, 0i32),
       then() { return(lengthStatus) },
       else() { })

    [i32] literalMaxBits{pngHuffmanMaxBitsSplitLiteralLengths(literalLengthsLow, literalLengthsHigh)}
    if(less_equal(literalMaxBits, 0i32),
       then() { return(1i32) },
       else() { })
    [i32] distanceMaxBits{pngHuffmanMaxBits(distanceLengths)}
    while(true, do() {
      [i32 mut] symbol{0i32}
      [i32] status{pngHuffmanDecodeSplitLiteralSymbol(compressed, byteIndex, bitIndex, literalLengthsLow,
                                                      literalLengthsHigh, literalMaxBits, symbol)}
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      if(less_than(symbol, 256i32),
         then() { push(output, symbol) },
         else() {
           if(equal(symbol, 256i32),
              then() { return(0i32) },
              else() {
                if(less_equal(distanceMaxBits, 0i32),
                   then() { return(1i32) },
                   else() { })
                [i32 mut] lengthBase{0i32}
                [i32 mut] lengthExtraBits{0i32}
                [i32] lengthInfoStatus{pngLengthInfo(symbol, lengthBase, lengthExtraBits)}
                if(not_equal(lengthInfoStatus, 0i32),
                   then() { return(1i32) },
                   else() { })

                [i32 mut] lengthExtraValue{0i32}
                if(greater_than(lengthExtraBits, 0i32),
                   then() {
                     [i32] lengthExtraStatus{pngReadBits(compressed, byteIndex, bitIndex, lengthExtraBits, lengthExtraValue)}
                     if(not_equal(lengthExtraStatus, 0i32),
                        then() { return(1i32) },
                        else() { })
                   },
                   else() { })
                [i32] matchLength{plus(lengthBase, lengthExtraValue)}

                [i32 mut] distanceSymbol{0i32}
                [i32] distanceStatus{pngHuffmanDecodeSymbol(compressed, byteIndex, bitIndex, distanceLengths,
                                                            distanceMaxBits, distanceSymbol)}
                if(not_equal(distanceStatus, 0i32),
                   then() { return(1i32) },
                   else() { })

                [i32 mut] distanceBase{0i32}
                [i32 mut] distanceExtraBits{0i32}
                [i32] distanceInfoStatus{pngDistanceInfo(distanceSymbol, distanceBase, distanceExtraBits)}
                if(not_equal(distanceInfoStatus, 0i32),
                   then() { return(1i32) },
                   else() { })

                [i32 mut] distanceExtraValue{0i32}
                if(greater_than(distanceExtraBits, 0i32),
                   then() {
                     [i32] distanceExtraStatus{pngReadBits(compressed, byteIndex, bitIndex, distanceExtraBits, distanceExtraValue)}
                     if(not_equal(distanceExtraStatus, 0i32),
                        then() { return(1i32) },
                        else() { })
                   },
                   else() { })

                [i32] copyStatus{pngInflateCopyFromOutput(output, plus(distanceBase, distanceExtraValue), matchLength)}
                if(not_equal(copyStatus, 0i32),
                   then() { return(1i32) },
                   else() { })
              })
         })
    })
    return(1i32)
  }

  [effects(heap_alloc), return<int>]
  pngInflateDeflateBlocks([vector<i32>] compressed, [vector<i32> mut] output) {
    clear(output)
    [i32] compressedCount{count(compressed)}
    if(less_than(compressedCount, 7i32),
       then() { return(1i32) },
       else() { })

    if(not(pngZlibHeaderValid(compressed[0i32], compressed[1i32])),
       then() { return(1i32) },
       else() { })

    [i32 mut] byteIndex{2i32}
    [i32 mut] bitIndex{0i32}
    while(true, do() {
      [i32 mut] isFinal{0i32}
      [i32] finalStatus{pngReadBits(compressed, byteIndex, bitIndex, 1i32, isFinal)}
      if(not_equal(finalStatus, 0i32),
         then() { return(1i32) },
         else() { })

      [i32 mut] blockType{0i32}
      [i32] blockStatus{pngReadBits(compressed, byteIndex, bitIndex, 2i32, blockType)}
      if(not_equal(blockStatus, 0i32),
         then() { return(1i32) },
         else() { })

      [i32 mut] inflateStatus{0i32}
      if(equal(blockType, 0i32),
         then() { assign(inflateStatus, pngInflateStoredBlock(compressed, byteIndex, bitIndex, output)) },
         else() {
           if(equal(blockType, 1i32),
              then() { assign(inflateStatus, pngInflateFixedHuffmanBlock(compressed, byteIndex, bitIndex, output)) },
              else() {
                if(equal(blockType, 2i32),
                   then() { assign(inflateStatus, pngInflateDynamicHuffmanBlock(compressed, byteIndex, bitIndex, output)) },
                   else() { return(1i32) })
              })
         })
      if(not_equal(inflateStatus, 0i32),
         then() { return(inflateStatus) },
         else() { })

      if(equal(isFinal, 1i32),
         then() {
           if(not_equal(bitIndex, 0i32),
              then() {
                assign(bitIndex, 0i32)
                assign(byteIndex, plus(byteIndex, 1i32))
              },
              else() { })
	          if(not_equal(minus(compressedCount, byteIndex), 4i32),
	             then() { return(1i32) },
	             else() { })
	          [i32] adlerBHigh{compressed[byteIndex]}
	          [i32] adlerBLow{compressed[plus(byteIndex, 1i32)]}
	          [i32] adlerAHigh{compressed[plus(byteIndex, 2i32)]}
	          [i32] adlerALow{compressed[plus(byteIndex, 3i32)]}
	          if(not(pngAdlerValid(output, adlerBHigh, adlerBLow, adlerAHigh, adlerALow)),
	             then() { return(1i32) },
	             else() { })
	          return(0i32)
         },
         else() { })
    })
    return(1i32)
  }

  [effects(heap_alloc), return<int>]
  pngDecodeScanlines([vector<i32>] rawBytes, [i32] width, [i32] height, [i32] bitDepth, [i32] colorType,
                     [i32] interlace, [vector<i32> mut] pixels) {
    clear(pixels)
    if(or(not_equal(bitDepth, 8i32), or(not_equal(interlace, 0i32), and(not_equal(colorType, 2i32), not_equal(colorType, 6i32)))),
       then() { return(2i32) },
       else() { })

    [i32] bytesPerPixel{if(equal(colorType, 2i32), then() { 3i32 }, else() { 4i32 })}
    [i32] scanlineBytes{multiply(width, bytesPerPixel)}
    if(not_equal(count(rawBytes), multiply(height, plus(scanlineBytes, 1i32))),
       then() { return(1i32) },
       else() { })

    [i32 mut] offset{0i32}
    [i32 mut] row{0i32}
    [vector<i32> mut] rowBytes{vector<i32>()}
    [vector<i32> mut] previousRowBytes{vector<i32>()}
    while(less_than(row, height), do() {
      [i32] filterType{rawBytes[offset]}
      if(and(and(and(and(not_equal(filterType, 0i32), not_equal(filterType, 1i32)), not_equal(filterType, 2i32)),
                 not_equal(filterType, 3i32)),
             not_equal(filterType, 4i32)),
         then() {
           clear(pixels)
           return(2i32)
         },
         else() { })
      assign(offset, plus(offset, 1i32))
      clear(rowBytes)

      [i32 mut] byteIndex{0i32}
      while(less_than(byteIndex, scanlineBytes), do() {
        [i32 mut] reconstructed{rawBytes[plus(offset, byteIndex)]}
        [i32 mut] leftByte{0i32}
        [i32 mut] upByte{0i32}
        [i32 mut] upLeftByte{0i32}
        if(greater_equal(byteIndex, bytesPerPixel),
           then() { assign(leftByte, rowBytes[minus(byteIndex, bytesPerPixel)]) },
           else() { })
        if(less_than(byteIndex, count(previousRowBytes)),
           then() { assign(upByte, previousRowBytes[byteIndex]) },
           else() { })
        if(and(greater_equal(byteIndex, bytesPerPixel), less_than(minus(byteIndex, bytesPerPixel), count(previousRowBytes)))),
           then() { assign(upLeftByte, previousRowBytes[minus(byteIndex, bytesPerPixel)]) },
           else() { })
        if(and(equal(filterType, 1i32), greater_equal(byteIndex, bytesPerPixel)),
           then() {
             assign(reconstructed, pngMod(plus(reconstructed, leftByte), 256i32))
           },
           else() { })
        if(and(equal(filterType, 2i32), less_than(byteIndex, count(previousRowBytes))),
           then() {
             assign(reconstructed, pngMod(plus(reconstructed, upByte), 256i32))
           },
           else() { })
        if(equal(filterType, 3i32),
           then() {
             assign(reconstructed, pngMod(plus(reconstructed, divide(plus(leftByte, upByte), 2i32)), 256i32))
           },
           else() { })
        if(equal(filterType, 4i32),
           then() {
             assign(reconstructed, pngMod(plus(reconstructed, pngPaethPredictor(leftByte, upByte, upLeftByte)), 256i32))
           },
           else() { })
        push(rowBytes, reconstructed)
        increment(byteIndex)
      })

      [i32 mut] pixelByteIndex{0i32}
      while(less_than(pixelByteIndex, scanlineBytes), do() {
        push(pixels, rowBytes[pixelByteIndex])
        push(pixels, rowBytes[plus(pixelByteIndex, 1i32)])
        push(pixels, rowBytes[plus(pixelByteIndex, 2i32)])
        assign(pixelByteIndex, plus(pixelByteIndex, bytesPerPixel))
      })
      clear(previousRowBytes)
      [i32 mut] previousRowIndex{0i32}
      while(less_than(previousRowIndex, scanlineBytes), do() {
        push(previousRowBytes, rowBytes[previousRowIndex])
        increment(previousRowIndex)
      })
      assign(offset, plus(offset, scanlineBytes))
      increment(row)
    })
    return(0i32)
  }

  namespace ppm {
    [effects(file_write, heap_alloc), return<int> on_error<FileError, /std/image/ignoreFileError>]
    readImpl([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      [File<Read>] file{File<Read>(path)?}
      [i32 mut] hasPending{0i32}
      [i32 mut] pendingByte{0i32}
      [i32 mut] byte{0i32}
      [i32 mut] formatByte{0i32}
      [i32 mut] status{ppmNextByte(file, hasPending, pendingByte, byte)}
      if(or(not_equal(status, 0i32), not_equal(byte, 80i32)),
         then() { return(1i32) },
         else() { })

      assign(status, ppmNextByte(file, hasPending, pendingByte, byte))
      if(or(not_equal(status, 0i32), and(not_equal(byte, 51i32), not_equal(byte, 54i32))),
         then() { return(1i32) },
         else() { assign(formatByte, byte) })
      assign(status, ppmNextByte(file, hasPending, pendingByte, byte))
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      if(or(ppmIsWhitespace(byte), equal(byte, 35i32)),
         then() {
           assign(hasPending, 1i32)
           assign(pendingByte, byte)
         },
         else() { return(1i32) })

      [i32 mut] parsedWidth{0i32}
      [i32 mut] parsedHeight{0i32}
      [i32 mut] maxValue{0i32}
      assign(status, ppmReadAsciiInt(file, hasPending, pendingByte, parsedWidth))
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      assign(status, ppmReadAsciiInt(file, hasPending, pendingByte, parsedHeight))
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })
      assign(status, ppmReadAsciiInt(file, hasPending, pendingByte, maxValue))
      if(or(or(not_equal(status, 0i32), not_equal(maxValue, 255i32)),
            or(less_equal(parsedWidth, 0i32), less_equal(parsedHeight, 0i32))),
         then() { return(1i32) },
         else() { })

      [i32] pixelCount{multiply(multiply(parsedWidth, parsedHeight), 3i32)}
      [i32 mut] index{0i32}
      [i32 mut] component{0i32}
      if(equal(formatByte, 51i32),
         then() {
           while(less_than(index, pixelCount), do() {
             assign(status, ppmReadAsciiInt(file, hasPending, pendingByte, component))
             if(or(not_equal(status, 0i32), or(less_than(component, 0i32), greater_than(component, 255i32))),
                then() {
                  resetReadOutputs(width, height, pixels)
                  return(1i32)
                },
                else() { })
             push(pixels, component)
             increment(index)
           })
         },
         else() {
           assign(status, ppmReadBinaryRasterLead(file, hasPending, pendingByte, component))
           if(not_equal(status, 0i32),
              then() { return(1i32) },
              else() { })
           push(pixels, component)
           assign(index, 1i32)
           while(less_than(index, pixelCount), do() {
             assign(status, ppmReadByteStatus(file, component))
             if(not_equal(status, 0i32),
                then() {
                  resetReadOutputs(width, height, pixels)
                  return(1i32)
                },
                else() { })
             push(pixels, component)
             increment(index)
           })
         })

      assign(width, parsedWidth)
      assign(height, parsedHeight)
      return(0i32)
    }

    [public return<Result<ImageError>> effects(file_write, heap_alloc)]
    read([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      resetReadOutputs(width, height, pixels)
      [i32] status{readImpl(width, height, pixels, path)}
      if(not_equal(status, 0i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(invalidOperation())
         },
         else() { })
      return(Result.ok())
    }

    [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
    writeImpl([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      if(not(ppmWriteInputValid(width, height, pixels)),
         then() { return(1i32) },
         else() { })

      [File<Write>] file{File<Write>(path)?}
      [i32 mut] status{ppmWriteHeader(file, width, height)}
      if(not_equal(status, 0i32),
         then() { return(1i32) },
         else() { })

      [i32] pixelCount{count(pixels)}
      [i32 mut] index{0i32}
      while(less_than(index, pixelCount), do() {
        assign(status, ppmWriteComponent(file, pixels[index]))
        if(not_equal(status, 0i32),
           then() { return(1i32) },
           else() { })
        increment(index)
      })
      return(0i32)
    }

    [public return<Result<ImageError>> effects(file_write)]
    write([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      [i32] status{writeImpl(path, width, height, pixels)}
      if(not_equal(status, 0i32),
         then() { return(invalidOperation()) },
         else() { })
      return(Result.ok())
    }
  }

  namespace png {
    [effects(file_write, heap_alloc), return<int> on_error<FileError, /std/image/ignoreFileError>]
    readImpl([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      [File<Read>] file{File<Read>(path)?}
      [i32] signatureStatus{pngValidateSignature(file)}
      if(not_equal(signatureStatus, 0i32),
         then() { return(1i32) },
         else() { })

      [i32 mut] sawIhdr{0i32}
      [i32 mut] sawIdat{0i32}
      [i32 mut] sawPlte{0i32}
      [i32 mut] sawPostIdatChunk{0i32}
      [i32 mut] parsedWidth{0i32}
      [i32 mut] parsedHeight{0i32}
      [i32 mut] bitDepth{0i32}
      [i32 mut] colorType{0i32}
      [i32 mut] interlace{0i32}
      [vector<i32> mut] idatBytes{vector<i32>()}
      [vector<i32> mut] rawBytes{vector<i32>()}
      while(true, do() {
        [i32 mut] chunkLength{0i32}
        [i32] lengthStatus{pngReadU32Be(file, chunkLength)}
        if(or(not_equal(lengthStatus, 0i32), less_than(chunkLength, 0i32)),
           then() { return(1i32) },
           else() { })

        [i32 mut] typeA{0i32}
        [i32 mut] typeB{0i32}
        [i32 mut] typeC{0i32}
        [i32 mut] typeD{0i32}
        [i32] typeStatus{pngReadChunkType(file, typeA, typeB, typeC, typeD)}
        if(not_equal(typeStatus, 0i32),
           then() { return(1i32) },
           else() { })

        if(equal(sawIhdr, 0i32),
           then() {
             if(or(not(pngChunkIsIhdr(typeA, typeB, typeC, typeD)), not_equal(chunkLength, 13i32)),
                then() { return(1i32) },
                else() { })
             assign(sawIhdr, 1i32)
             [i32] ihdrStatus{pngReadIhdr(file, parsedWidth, parsedHeight, bitDepth, colorType, interlace)}
             if(not_equal(ihdrStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [i32 mut] ihdrCrcA{0i32}
             [i32 mut] ihdrCrcB{0i32}
             [i32 mut] ihdrCrcC{0i32}
             [i32 mut] ihdrCrcD{0i32}
             [i32] ihdrCrcStatus{pngReadChunkType(file, ihdrCrcA, ihdrCrcB, ihdrCrcC, ihdrCrcD)}
             if(not_equal(ihdrCrcStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [vector<i32> mut] ihdrBytes{vector<i32>()}
             pngAppendU32Be(parsedWidth, ihdrBytes)
             pngAppendU32Be(parsedHeight, ihdrBytes)
             push(ihdrBytes, bitDepth)
             push(ihdrBytes, colorType)
             push(ihdrBytes, 0i32)
             push(ihdrBytes, 0i32)
             push(ihdrBytes, interlace)
             if(not(pngChunkCrcMatches(typeA, typeB, typeC, typeD, ihdrBytes, ihdrCrcA, ihdrCrcB, ihdrCrcC, ihdrCrcD))),
                then() { return(1i32) },
                else() { })
           },
           else() {
             if(pngChunkIsIhdr(typeA, typeB, typeC, typeD),
                then() { return(1i32) },
                else() { })
             if(pngChunkIsPlte(typeA, typeB, typeC, typeD),
                then() {
                  if(or(not_equal(sawPlte, 0i32), not_equal(sawIdat, 0i32)),
                     then() { return(1i32) },
                     else() { })
                  assign(sawPlte, 1i32)
                },
                else() { })
             if(and(not_equal(sawPostIdatChunk, 0i32), pngChunkIsIdat(typeA, typeB, typeC, typeD)),
                then() { return(1i32) },
                else() { })
             if(and(not_equal(sawIdat, 0i32),
                    and(not(pngChunkIsIdat(typeA, typeB, typeC, typeD)),
                        and(not(pngChunkIsIend(typeA, typeB, typeC, typeD)),
                            not(pngChunkIsAncillary(typeA))))),
                then() { return(1i32) },
                else() { })
             [vector<i32> mut] chunkBytes{vector<i32>()}
             [i32] payloadStatus{pngAppendBytes(file, chunkLength, chunkBytes)}
             if(not_equal(payloadStatus, 0i32),
                then() { return(1i32) },
                else() { })
             [i32 mut] crcA{0i32}
             [i32 mut] crcB{0i32}
             [i32 mut] crcC{0i32}
             [i32 mut] crcD{0i32}
             [i32] crcStatus{pngReadChunkType(file, crcA, crcB, crcC, crcD)}
             if(not_equal(crcStatus, 0i32),
                then() { return(1i32) },
                else() { })
             if(and(not(pngChunkIsAncillary(typeA)),
                    not(pngChunkCrcMatches(typeA, typeB, typeC, typeD, chunkBytes, crcA, crcB, crcC, crcD))),
                then() { return(1i32) },
                else() { })
             if(and(not_equal(sawIdat, 0i32), not(pngChunkIsIdat(typeA, typeB, typeC, typeD))),
                then() { assign(sawPostIdatChunk, 1i32) },
                else() { })
             if(pngChunkIsIdat(typeA, typeB, typeC, typeD),
                then() {
                  assign(sawIdat, 1i32)
                  pngAppendVectorBytes(chunkBytes, idatBytes)
                },
                else() { })
             if(pngChunkIsIend(typeA, typeB, typeC, typeD),
                then() {
                  if(or(not_equal(chunkLength, 0i32), equal(sawIdat, 0i32)),
                     then() { return(1i32) },
                     else() {
                       [i32] inflateStatus{pngInflateDeflateBlocks(idatBytes, rawBytes)}
                       if(equal(inflateStatus, 1i32),
                          then() { return(1i32) },
                          else() { })
                       if(equal(inflateStatus, 2i32),
                          then() { return(2i32) },
                          else() { })

                       [i32] decodeStatus{pngDecodeScanlines(rawBytes, parsedWidth, parsedHeight, bitDepth, colorType, interlace, pixels)}
                       if(equal(decodeStatus, 1i32),
                          then() {
                            resetReadOutputs(width, height, pixels)
                            return(1i32)
                          },
                          else() { })
                       if(equal(decodeStatus, 2i32),
                          then() {
                            resetReadOutputs(width, height, pixels)
                            return(2i32)
                          },
                          else() { })

                       assign(width, parsedWidth)
                       assign(height, parsedHeight)
                       return(0i32)
                     })
                },
                else() { })
           })
      })
      return(1i32)
    }

    [public return<Result<ImageError>> effects(file_write, heap_alloc)]
    read([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels, [string] path) {
      resetReadOutputs(width, height, pixels)
      [i32] status{readImpl(width, height, pixels, path)}
      if(equal(status, 1i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(invalidOperation())
         },
         else() { })
      if(equal(status, 2i32),
         then() {
           resetReadOutputs(width, height, pixels)
           return(unsupported_read())
         },
         else() { })
      return(Result.ok())
    }

    [public return<Result<ImageError>> effects(file_write)]
    write([string] path, [i32] width, [i32] height, [vector<i32>] pixels) {
      return(unsupported_write())
    }
  }
  }
}
