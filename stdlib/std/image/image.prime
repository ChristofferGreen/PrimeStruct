       then() {
         assign(bitIndex, 0i32)
         assign(byteIndex, plus(byteIndex, 1i32))
       },
       else() { })

    [i32] trailerStart{minus(count(compressed), 4i32)}
    if(greater_than(plus(byteIndex, 4i32), trailerStart),
       then() { return(1i32) },
       else() { })

    [i32] blockLen{plus(compressed[byteIndex], multiply(compressed[plus(byteIndex, 1i32)], 256i32))}
    [i32] blockNlen{plus(compressed[plus(byteIndex, 2i32)], multiply(compressed[plus(byteIndex, 3i32)], 256i32))}
    if(not_equal(plus(blockLen, blockNlen), 65535i32),
       then() { return(1i32) },
       else() { })
    assign(byteIndex, plus(byteIndex, 4i32))

    if(greater_than(plus(byteIndex, blockLen), trailerStart),
       then() { return(1i32) },
       else() { })
    [i32 mut] blockIndex{0i32}
    while(less_than(blockIndex, blockLen), do() {
      push(output, compressed[plus(byteIndex, blockIndex)])
      increment(blockIndex)
    })
    assign(byteIndex, plus(byteIndex, blockLen))
    return(0i32)
  }

  [effects(heap_alloc), return<int>]
  pngInflateHuffmanBlock([vector<i32>] compressed, [i32 mut] byteIndex, [i32 mut] bitIndex,
                         [vector<i32>] literalLengths, [i32] literalMaxBits, [vector<i32>] distanceLengths,
                         [i32] distanceMaxBits, [i32] allowBackreferences, [vector<i32> mut] output) {
    if(less_equal(literalMaxBits, 0i32),
       then() { return(1i32) },
       else() { })
    while(true, do() {
      [i32 mut] symbol{0i32}
