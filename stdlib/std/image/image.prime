              else() { })
	          if(not_equal(compressedCount - byteIndex, 4i32),
	             then() { return(1i32) },
	             else() { })
	          adlerBHigh{compressed[byteIndex]}
	          adlerBLow{compressed[byteIndex + 1i32]}
	          adlerAHigh{compressed[byteIndex + 2i32]}
	          adlerALow{compressed[byteIndex + 3i32]}
	          if(not(pngAdlerValid(output, adlerBHigh, adlerBLow, adlerAHigh, adlerALow)),
	             then() { return(1i32) },
	             else() { })
