import /std/math/*
import /std/file/*
import /std/collections/*

[public return<string>]
/ImageError/why([/std/image/ImageError] err) {
  return(/std/image/ImageError/why(err))
}

[public return<Result</std/image/ImageError>>]
/ImageError/status([/std/image/ImageError] err) {
  return(/std/image/ImageError/status(err))
}

[public return</std/image/ImageError>]
/ImageError/read_unsupported() {
  return(/std/image/ImageError/read_unsupported())
}

[public return</std/image/ImageError>]
/ImageError/write_unsupported() {
  return(/std/image/ImageError/write_unsupported())
}

[public return</std/image/ImageError>]
/ImageError/invalid_operation() {
  return(/std/image/ImageError/invalid_operation())
}

[public return<Result<T, /std/image/ImageError>>]
/ImageError/result<T>([/std/image/ImageError] err) {
  return(/std/image/ImageError/result<T>(err))
}

namespace std {
  namespace image {
  [public struct]
  ImageError() {
    [public i32] code{0i32}
  }

  namespace ImageError {
    [public return<string>]
    why([ImageError] err) {
      return(
        if(equal(err.code, 1i32),
          then() { "image_read_unsupported"utf8 },
          else() {
            if(equal(err.code, 2i32),
              then() { "image_write_unsupported"utf8 },
              else() { "image_invalid_operation"utf8 })
          }))
    }

    [public return<Result<ImageError>>]
    status([ImageError] err) {
      return(err.code)
    }

    [public return<ImageError>]
    read_unsupported() {
      return(ImageError(1i32))
    }

    [public return<ImageError>]
    write_unsupported() {
      return(ImageError(2i32))
    }

    [public return<ImageError>]
    invalid_operation() {
      return(ImageError(3i32))
    }

    [public return<Result<T, ImageError>>]
    result<T>([ImageError] err) {
      return(multiply(convert<i64>(err.code), 4294967296i64))
    }
  }

  [public return<ImageError>]
  imageReadUnsupported() {
    return(/std/image/ImageError/read_unsupported())
  }

  [public return<ImageError>]
  imageWriteUnsupported() {
    return(/std/image/ImageError/write_unsupported())
  }

  [public return<ImageError>]
  imageInvalidOperation() {
