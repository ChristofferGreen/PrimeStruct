           },
           else() { })
        increment(symbolIndex)
      })
    })
    return(1i32)
  }

  [return<int>]
  pngLengthInfo([i32] symbol, [i32 mut] baseOut, [i32 mut] extraBitsOut) {
    assign(baseOut, 0i32)
    assign(extraBitsOut, 0i32)
    if(less_than(symbol, 257i32),
       then() { return(1i32) },
       else() { })
    if(less_equal(symbol, 264i32),
       then() {
         assign(baseOut, plus(3i32, minus(symbol, 257i32)))
         return(0i32)
       },
       else() { })
    if(equal(symbol, 285i32),
       then() {
         assign(baseOut, 258i32)
         return(0i32)
       },
       else() { })
    if(greater_than(symbol, 284i32),
       then() { return(1i32) },
       else() { })

    [i32 mut] base{11i32}
    [i32 mut] currentSymbol{265i32}
    [i32 mut] step{2i32}
    [i32 mut] extraBits{1i32}
    while(greater_than(symbol, plus(currentSymbol, 3i32)), do() {
      assign(base, plus(base, multiply(step, 4i32)))
      assign(currentSymbol, plus(currentSymbol, 4i32))
      assign(step, multiply(step, 2i32))
      increment(extraBits)
    })
    assign(baseOut, plus(base, multiply(minus(symbol, currentSymbol), step)))
    assign(extraBitsOut, extraBits)
    return(0i32)
  }

  [return<int>]
  pngDistanceInfo([i32] symbol, [i32 mut] baseOut, [i32 mut] extraBitsOut) {
    assign(baseOut, 0i32)
    assign(extraBitsOut, 0i32)
    if(or(less_than(symbol, 0i32), greater_than(symbol, 29i32)),
       then() { return(1i32) },
       else() { })
    if(less_equal(symbol, 3i32),
       then() {
         assign(baseOut, plus(symbol, 1i32))
         return(0i32)
       },
       else() { })

    [i32 mut] base{5i32}
    [i32 mut] currentSymbol{4i32}
    [i32 mut] span{4i32}
    [i32 mut] extraBits{1i32}
    while(greater_than(symbol, plus(currentSymbol, 1i32)), do() {
      assign(base, plus(base, span))
      assign(currentSymbol, plus(currentSymbol, 2i32))
      assign(span, multiply(span, 2i32))
      increment(extraBits)
    })
    if(equal(minus(symbol, currentSymbol), 1i32),
       then() { assign(base, plus(base, divide(span, 2i32))) },
       else() { })
    assign(baseOut, base)
    assign(extraBitsOut, extraBits)
    return(0i32)
  }

  [effects(heap_alloc), return<int>]
  pngInflateCopyFromOutput([vector<i32> mut] output, [i32] distance, [i32] length) {
