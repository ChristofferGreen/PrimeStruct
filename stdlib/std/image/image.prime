import /std/math/*
import /std/file/*
import /std/collections/*

[public return<string>]
/ImageError/why([/std/image/ImageError] err) {
  return(/std/image/ImageError/why(err))
}

[public return<Result</std/image/ImageError>>]
/ImageError/status([/std/image/ImageError] err) {
  return(/std/image/ImageError/status(err))
}

[public return</std/image/ImageError>]
/ImageError/read_unsupported() {
  return(/std/image/ImageError/read_unsupported())
}

[public return</std/image/ImageError>]
/ImageError/write_unsupported() {
  return(/std/image/ImageError/write_unsupported())
}

[public return</std/image/ImageError>]
/ImageError/invalid_operation() {
  return(/std/image/ImageError/invalid_operation())
}

[public return<Result<T, /std/image/ImageError>>]
/ImageError/result<T>([/std/image/ImageError] err) {
  return(/std/image/ImageError/result<T>(err))
}

namespace std {
  namespace image {
  [public struct]
  ImageError() {
    [public i32] code{0i32}
  }

  namespace ImageError {
    [public return<string>]
    why([ImageError] err) {
      return(
        if(equal(err.code, 1i32),
          then() { "image_read_unsupported"utf8 },
          else() {
            if(equal(err.code, 2i32),
              then() { "image_write_unsupported"utf8 },
              else() { "image_invalid_operation"utf8 })
          }))
    }

    [public return<Result<ImageError>>]
    status([ImageError] err) {
      return(err.code)
    }

    [public return<ImageError>]
    read_unsupported() {
      return(ImageError(1i32))
    }

    [public return<ImageError>]
    write_unsupported() {
      return(ImageError(2i32))
    }

    [public return<ImageError>]
    invalid_operation() {
      return(ImageError(3i32))
    }

    [public return<Result<T, ImageError>>]
    result<T>([ImageError] err) {
      return(multiply(convert<i64>(err.code), 4294967296i64))
    }
  }

  [public return<ImageError>]
  imageReadUnsupported() {
    return(/std/image/ImageError/read_unsupported())
  }

  [public return<ImageError>]
  imageWriteUnsupported() {
    return(/std/image/ImageError/write_unsupported())
  }

  [public return<ImageError>]
  imageInvalidOperation() {
    return(/std/image/ImageError/invalid_operation())
  }

  [public return<Result<ImageError>>]
  imageErrorStatus([ImageError] err) {
    return(/std/image/ImageError/status(err))
  }

  [public return<Result<T, ImageError>>]
  imageErrorResult<T>([ImageError] err) {
    return(/std/image/ImageError/result<T>(err))
  }

  [return<Result<ImageError>>]
  unsupported_read() {
    return(imageErrorStatus(/ImageError/read_unsupported()))
  }

  [return<Result<ImageError>>]
  unsupported_write() {
    return(imageErrorStatus(/ImageError/write_unsupported()))
  }

  [return<Result<ImageError>>]
  invalidOperation() {
    return(imageErrorStatus(/ImageError/invalid_operation()))
  }

  [return<void>]
  ignoreFileError([FileError] err) {
  }

  [return<bool>]
  ppmIsWhitespace([i32] value) {
    return(or(or(equal(value, 32i32), equal(value, 9i32)), or(equal(value, 10i32), equal(value, 13i32))))
  }

  [return<bool>]
  ppmIsDigit([i32] value) {
    return(and(greater_equal(value, 48i32), less_equal(value, 57i32)))
  }

  [return<i32>]
  ppmDigitValue([i32] value) {
    return(value - 48i32)
  }

  [effects(file_read), return<int> on_error<FileError, /std/image/ignoreFileError>]
  ppmReadByteStatus([File<Read>] file, [i32 mut] value) {
    file.read_byte(value)?
    return(0i32)
  }

  [effects(file_read), return<int>]
  ppmSkipComment([File<Read>] file) {
    [mut] byte{0i32}
    while(true, do() {
      status{ppmReadByteStatus(file, byte)}
      if(not_equal(status, 0i32),
         then() {
           if(fileErrorIsEof(status),
              then() { return(0i32) },
              else() { return(status) })
         },
         else() { })
      if(or(equal(byte, 10i32), equal(byte, 13i32)),
         then() { return(0i32) },
         else() { })
    })
    return(0i32)
  }

  [effects(file_read), return<int>]
  ppmNextByte([File<Read>] file, [i32 mut] hasPending, [i32 mut] pendingByte, [i32 mut] value) {
    if(equal(hasPending, 1i32),
       then() {
         value = pendingByte
         hasPending = 0i32
         return(0i32)
       },
       else() { })
    return(ppmReadByteStatus(file, value))
  }

  [effects(file_read), return<int>]
  ppmReadAsciiInt([File<Read>] file, [i32 mut] hasPending, [i32 mut] pendingByte, [i32 mut] value) {
    value = 0i32
    [mut] started{0i32}
    [mut] byte{0i32}
    while(true, do() {
      status{ppmNextByte(file, hasPending, pendingByte, byte)}
      if(not_equal(status, 0i32),
         then() {
           if(equal(started, 1i32),
              then() {
                if(fileErrorIsEof(status),
                   then() { return(0i32) },
                   else() { return(status) })
              },
              else() { return(status) })
         },
         else() { })
      if(equal(started, 0i32),
         then() {
           if(ppmIsWhitespace(byte),
              then() { },
              else() {
                if(equal(byte, 35i32),
                   then() {
                     commentStatus{ppmSkipComment(file)}
                     if(not_equal(commentStatus, 0i32),
                        then() { return(commentStatus) },
                        else() { })
                   },
                   else() {
                     if(ppmIsDigit(byte),
                        then() {
                          started = 1i32
                          value = ppmDigitValue(byte)
                        },
                        else() { return(1i32) })
                   })
              })
         },
         else() {
           if(ppmIsDigit(byte),
              then() { value = multiply(value, 10i32) + ppmDigitValue(byte) },
              else() {
                hasPending = 1i32
                pendingByte = byte
                return(0i32)
              })
         })
    })
    return(0i32)
  }

  [effects(file_read), return<int>]
  ppmReadBinaryRasterLead([File<Read>] file, [i32 mut] hasPending, [i32 mut] pendingByte, [i32 mut] value) {
    [mut] sawWhitespace{0i32}
    while(true, do() {
      status{ppmNextByte(file, hasPending, pendingByte, value)}
      if(not_equal(status, 0i32),
         then() { return(status) },
         else() { })
      if(ppmIsWhitespace(value),
         then() { sawWhitespace = 1i32 },
         else() {
           if(equal(sawWhitespace, 1i32),
              then() { return(0i32) },
              else() { return(1i32) })
         })
    })
    return(0i32)
  }

  [effects(heap_alloc), return<void>]
  resetReadOutputs([i32 mut] width, [i32 mut] height, [vector<i32> mut] pixels) {
    width = 0i32
    height = 0i32
    /std/collections/vector/clear(pixels)
  }

  [return<bool>]
  imageRgbWritePixelCount([i32] width, [i32] height, [i32 mut] pixelCount) {
    pixelCount = 0i32
    if(or(less_equal(width, 0i32), less_equal(height, 0i32)),
       then() { return(false) },
       else() { })

    pixelCountWide{multiply(multiply(convert<i64>(width), convert<i64>(height)), 3i64)}
    if(or(less_equal(pixelCountWide, 0i64), greater_than(pixelCountWide, 2147483647i64)),
       then() { return(false) },
       else() { })
    pixelCount = convert<i32>(pixelCountWide)
    return(true)
  }

  [return<bool>]
  ppmWriteInputValid([i32] width, [i32] height, [vector<i32>] pixels) {
    pixelCount{count(pixels)}
    [mut] expectedPixelCount{0i32}
    if(not(imageRgbWritePixelCount(width, height, expectedPixelCount)),
       then() { return(false) },
       else() { })
    if(not_equal(pixelCount, expectedPixelCount),
       then() { return(false) },
       else() { })

    [mut] index{0i32}
    while(less_than(index, pixelCount), do() {
      component{pixels[index]}
      if(or(less_than(component, 0i32), greater_than(component, 255i32)),
         then() { return(false) },
         else() { })
      increment(index)
    })
    return(true)
  }

  [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
  ppmWriteHeader([File<Write>] file, [i32] width, [i32] height) {
    file.write("P3\n"utf8, width, " "utf8, height, "\n255\n"utf8)?
    return(0i32)
  }

  [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
  ppmWriteComponent([File<Write>] file, [i32] value) {
    file.write(value, "\n"utf8)?
    return(0i32)
  }

  [effects(file_read), return<int>]
  pngReadU32Be([File<Read>] file, [i32 mut] value) {
    value = 0i32
    [mut] index{0i32}
    [mut] byte{0i32}
    while(less_than(index, 4i32), do() {
      status{ppmReadByteStatus(file, byte)}
      if(not_equal(status, 0i32),
         then() { return(status) },
         else() { })
      if(or(less_than(byte, 0i32), greater_than(byte, 255i32)),
         then() { return(1i32) },
         else() { })
      value = multiply(value, 256i32) + byte
      increment(index)
    })
    return(0i32)
  }

  [effects(file_read), return<int>]
  pngSkipBytes([File<Read>] file, [i32] count) {
    if(less_than(count, 0i32),
       then() { return(1i32) },
       else() { })
    [mut] remaining{count}
    [mut] byte{0i32}
    while(greater_than(remaining, 0i32), do() {
      status{ppmReadByteStatus(file, byte)}
      if(not_equal(status, 0i32),
         then() { return(status) },
         else() { })
      remaining = remaining - 1i32
    })
    return(0i32)
  }

  [effects(file_read), return<int>]
  pngReadChunkType([File<Read>] file, [i32 mut] a, [i32 mut] b, [i32 mut] c, [i32 mut] d) {
    statusA{ppmReadByteStatus(file, a)}
    if(not_equal(statusA, 0i32),
       then() { return(statusA) },
       else() { })
    statusB{ppmReadByteStatus(file, b)}
    if(not_equal(statusB, 0i32),
       then() { return(statusB) },
       else() { })
    statusC{ppmReadByteStatus(file, c)}
    if(not_equal(statusC, 0i32),
       then() { return(statusC) },
       else() { })
    return(ppmReadByteStatus(file, d))
  }

  [return<bool>]
  pngChunkIsIhdr([i32] a, [i32] b, [i32] c, [i32] d) {
    return(and(and(equal(a, 73i32), equal(b, 72i32)), and(equal(c, 68i32), equal(d, 82i32))))
  }

  [return<bool>]
  pngChunkIsIdat([i32] a, [i32] b, [i32] c, [i32] d) {
    return(and(and(equal(a, 73i32), equal(b, 68i32)), and(equal(c, 65i32), equal(d, 84i32))))
  }

  [return<bool>]
  pngChunkIsIend([i32] a, [i32] b, [i32] c, [i32] d) {
    return(and(and(equal(a, 73i32), equal(b, 69i32)), and(equal(c, 78i32), equal(d, 68i32))))
  }

  [return<bool>]
  pngChunkIsPlte([i32] a, [i32] b, [i32] c, [i32] d) {
    return(and(and(equal(a, 80i32), equal(b, 76i32)), and(equal(c, 84i32), equal(d, 69i32))))
  }

  [return<bool>]
  pngChunkIsAncillary([i32] a) {
    return(and(greater_equal(a, 97i32), less_equal(a, 122i32)))
  }

  [return<bool>]
  pngBitDepthAllowed([i32] bitDepth, [i32] a, [i32] b, [i32] c, [i32] d, [i32] valueE) {
    return(or(or(equal(bitDepth, a), equal(bitDepth, b)), or(or(equal(bitDepth, c), equal(bitDepth, d)), equal(bitDepth, valueE))))
  }

  [return<bool>]
  pngIhdrFieldsValid([i32] bitDepth, [i32] colorType, [i32] compression, [i32] filter, [i32] interlace) {
    if(or(not_equal(compression, 0i32), or(not_equal(filter, 0i32), and(not_equal(interlace, 0i32), not_equal(interlace, 1i32)))),
       then() { return(false) },
       else() { })
    if(equal(colorType, 0i32),
       then() { return(pngBitDepthAllowed(bitDepth, 1i32, 2i32, 4i32, 8i32, 16i32)) },
       else() { })
    if(equal(colorType, 2i32),
       then() { return(or(equal(bitDepth, 8i32), equal(bitDepth, 16i32))) },
       else() { })
    if(equal(colorType, 3i32),
       then() { return(pngBitDepthAllowed(bitDepth, 1i32, 2i32, 4i32, 8i32, -1i32)) },
       else() { })
    if(equal(colorType, 4i32),
       then() { return(or(equal(bitDepth, 8i32), equal(bitDepth, 16i32))) },
       else() { })
    if(equal(colorType, 6i32),
       then() { return(or(equal(bitDepth, 8i32), equal(bitDepth, 16i32))) },
       else() { })
    return(false)
  }

  [effects(file_read), return<int>]
  pngValidateSignature([File<Read>] file) {
    [mut] byte{0i32}
    status0{ppmReadByteStatus(file, byte)}
    if(not_equal(status0, 0i32),
       then() { return(status0) },
       else() { })
    if(not_equal(byte, 137i32),
       then() { return(1i32) },
       else() { })
    status1{ppmReadByteStatus(file, byte)}
    if(not_equal(status1, 0i32),
       then() { return(status1) },
       else() { })
    if(not_equal(byte, 80i32),
       then() { return(1i32) },
       else() { })
    status2{ppmReadByteStatus(file, byte)}
    if(not_equal(status2, 0i32),
       then() { return(status2) },
       else() { })
    if(not_equal(byte, 78i32),
       then() { return(1i32) },
       else() { })
    status3{ppmReadByteStatus(file, byte)}
    if(not_equal(status3, 0i32),
       then() { return(status3) },
       else() { })
    if(not_equal(byte, 71i32),
       then() { return(1i32) },
       else() { })
    status4{ppmReadByteStatus(file, byte)}
    if(not_equal(status4, 0i32),
       then() { return(status4) },
       else() { })
    if(not_equal(byte, 13i32),
       then() { return(1i32) },
       else() { })
    status5{ppmReadByteStatus(file, byte)}
    if(not_equal(status5, 0i32),
       then() { return(status5) },
       else() { })
    if(not_equal(byte, 10i32),
       then() { return(1i32) },
       else() { })
    status6{ppmReadByteStatus(file, byte)}
    if(not_equal(status6, 0i32),
       then() { return(status6) },
       else() { })
    if(not_equal(byte, 26i32),
       then() { return(1i32) },
       else() { })
    status7{ppmReadByteStatus(file, byte)}
    if(not_equal(status7, 0i32),
       then() { return(status7) },
       else() { })
    if(not_equal(byte, 10i32),
       then() { return(1i32) },
       else() { })
    return(0i32)
  }

  [effects(file_read), return<int>]
  pngReadIhdr([File<Read>] file, [i32 mut] width, [i32 mut] height, [i32 mut] bitDepthOut,
              [i32 mut] colorTypeOut, [i32 mut] interlaceOut) {
    [mut] parsedWidth{0i32}
    [mut] parsedHeight{0i32}
    widthStatus{pngReadU32Be(file, parsedWidth)}
    if(not_equal(widthStatus, 0i32),
       then() { return(widthStatus) },
       else() { })
    heightStatus{pngReadU32Be(file, parsedHeight)}
    if(not_equal(heightStatus, 0i32),
       then() { return(heightStatus) },
       else() { })
    [mut] bitDepth{0i32}
    bitDepthStatus{ppmReadByteStatus(file, bitDepth)}
    if(not_equal(bitDepthStatus, 0i32),
       then() { return(bitDepthStatus) },
       else() { })
    [mut] colorType{0i32}
    colorTypeStatus{ppmReadByteStatus(file, colorType)}
    if(not_equal(colorTypeStatus, 0i32),
       then() { return(colorTypeStatus) },
       else() { })
    [mut] compression{0i32}
    compressionStatus{ppmReadByteStatus(file, compression)}
    if(not_equal(compressionStatus, 0i32),
       then() { return(compressionStatus) },
       else() { })
    [mut] filter{0i32}
    filterStatus{ppmReadByteStatus(file, filter)}
    if(not_equal(filterStatus, 0i32),
       then() { return(filterStatus) },
       else() { })
    [mut] interlace{0i32}
    interlaceStatus{ppmReadByteStatus(file, interlace)}
    if(not_equal(interlaceStatus, 0i32),
       then() { return(interlaceStatus) },
       else() { })
    if(or(or(less_equal(parsedWidth, 0i32), less_equal(parsedHeight, 0i32)),
          not(pngIhdrFieldsValid(bitDepth, colorType, compression, filter, interlace))),
       then() { return(1i32) },
       else() { })
    width = parsedWidth
    height = parsedHeight
    bitDepthOut = bitDepth
    colorTypeOut = colorType
    interlaceOut = interlace
    return(0i32)
  }

  [return<i32>]
  pngMod([i32] value, [i32] divisor) {
    return(value - multiply(divide(value, divisor), divisor))
  }

  [return<u64>]
  pngModU64([u64] value, [u64] divisor) {
    return(value - multiply(divide(value, divisor), divisor))
  }

  [return<u64>]
  pngXorU64([u64] left, [u64] right) {
    [mut] currentLeft{left}
    [mut] currentRight{right}
    [mut] factor{1u64}
    [mut] value{0u64}
    while(or(greater_than(currentLeft, 0u64), greater_than(currentRight, 0u64)), do() {
      leftBit{pngModU64(currentLeft, 2u64)}
      rightBit{pngModU64(currentRight, 2u64)}
      if(not_equal(leftBit, rightBit),
         then() { value = value + factor },
         else() { })
      currentLeft = divide(currentLeft, 2u64)
      currentRight = divide(currentRight, 2u64)
      factor = multiply(factor, 2u64)
    })
    return(value)
  }

  [effects(heap_alloc), return<void>]
  pngAppendVectorBytes([vector<i32>] bytes, [vector<i32> mut] out) {
    [mut] index{0i32}
    while(less_than(index, count(bytes)), do() {
      /std/collections/vector/push(out, bytes[index])
      increment(index)
    })
  }

  [effects(heap_alloc), return<void>]
  pngAppendU32Be([i32] value, [vector<i32> mut] out) {
    /std/collections/vector/push(out, divide(value, 16777216i32))
    /std/collections/vector/push(out, pngMod(divide(value, 65536i32), 256i32))
    /std/collections/vector/push(out, pngMod(divide(value, 256i32), 256i32))
    /std/collections/vector/push(out, pngMod(value, 256i32))
  }

  [return<u64>]
  pngCrc32UpdateByte([u64] crc, [i32] byte) {
    [mut] current{pngXorU64(crc, convert<u64>(byte))}
    [mut] bit{0i32}
    while(less_than(bit, 8i32), do() {
      if(equal(pngModU64(current, 2u64), 1u64),
         then() {
           current = pngXorU64(divide(current, 2u64), 3988292384u64)
         },
         else() {
           current = divide(current, 2u64)
         })
      increment(bit)
    })
    return(current)
  }

  [return<u64>]
  pngChunkCrc([i32] typeA, [i32] typeB, [i32] typeC, [i32] typeD, [vector<i32>] payload) {
    [mut] crc{4294967295u64}
    crc = pngCrc32UpdateByte(crc, typeA)
    crc = pngCrc32UpdateByte(crc, typeB)
    crc = pngCrc32UpdateByte(crc, typeC)
    crc = pngCrc32UpdateByte(crc, typeD)
    [mut] index{0i32}
    while(less_than(index, count(payload)), do() {
      crc = pngCrc32UpdateByte(crc, payload[index])
      increment(index)
    })
    return(pngXorU64(crc, 4294967295u64))
  }

  [return<bool>]
  pngChunkCrcMatches([i32] typeA, [i32] typeB, [i32] typeC, [i32] typeD, [vector<i32>] payload,
                     [i32] crcA, [i32] crcB, [i32] crcC, [i32] crcD) {
    crc{pngChunkCrc(typeA, typeB, typeC, typeD, payload)}
    return(and(and(equal(divide(crc, 16777216u64), convert<u64>(crcA)),
                   equal(pngModU64(divide(crc, 65536u64), 256u64), convert<u64>(crcB))),
               and(equal(pngModU64(divide(crc, 256u64), 256u64), convert<u64>(crcC)),
                   equal(pngModU64(crc, 256u64), convert<u64>(crcD)))))
  }

  [effects(file_write), return<int> on_error<FileError, /std/image/ignoreFileError>]
  pngWriteByte([File<Write>] file, [i32] value) {
    if(or(less_than(value, 0i32), greater_than(value, 255i32)),
       then() { return(1i32) },
       else() { })
    file.write_byte(value)?
    return(0i32)
  }

  [effects(file_write), return<int>]
  pngWriteU32Be([File<Write>] file, [i32] value) {
    if(less_than(value, 0i32),
       then() { return(1i32) },
       else() { })
    byteA{divide(value, 16777216i32)}
    byteB{pngMod(divide(value, 65536i32), 256i32)}
    byteC{pngMod(divide(value, 256i32), 256i32)}
    byteD{pngMod(value, 256i32)}
    statusA{pngWriteByte(file, byteA)}
    if(not_equal(statusA, 0i32),
       then() { return(statusA) },
       else() { })
    statusB{pngWriteByte(file, byteB)}
    if(not_equal(statusB, 0i32),
       then() { return(statusB) },
       else() { })
    statusC{pngWriteByte(file, byteC)}
    if(not_equal(statusC, 0i32),
       then() { return(statusC) },
       else() { })
    return(pngWriteByte(file, byteD))
  }

  [effects(file_write), return<int>]
  pngWriteU32BeU64([File<Write>] file, [u64] value) {
    byteA{convert<i32>(divide(value, 16777216u64))}
    byteB{convert<i32>(pngModU64(divide(value, 65536u64), 256u64))}
    byteC{convert<i32>(pngModU64(divide(value, 256u64), 256u64))}
    byteD{convert<i32>(pngModU64(value, 256u64))}
    statusA{pngWriteByte(file, byteA)}
    if(not_equal(statusA, 0i32),
       then() { return(statusA) },
       else() { })
    statusB{pngWriteByte(file, byteB)}
    if(not_equal(statusB, 0i32),
       then() { return(statusB) },
       else() { })
    statusC{pngWriteByte(file, byteC)}
    if(not_equal(statusC, 0i32),
       then() { return(statusC) },
       else() { })
    return(pngWriteByte(file, byteD))
  }

  [effects(file_write), return<int>]
  pngWriteChunkOpen([File<Write>] file, [i32] length, [i32] typeA, [i32] typeB, [i32] typeC, [i32] typeD,
                    [u64 mut] crc) {
    crc = 4294967295u64
    lengthStatus{pngWriteU32Be(file, length)}
    if(not_equal(lengthStatus, 0i32),
       then() { return(lengthStatus) },
