#!/usr/bin/env bash
set -euo pipefail
out=""
while [[ $# -gt 0 ]]; do
  if [[ "$1" == "-o" ]]; then
    out="$2"
    shift 2
    continue
  fi
  shift
done
cat > "$out" <<'EOS'
#!/usr/bin/env bash
cat <<'EOD'
17001
1
1280
720
0
0
0
50
