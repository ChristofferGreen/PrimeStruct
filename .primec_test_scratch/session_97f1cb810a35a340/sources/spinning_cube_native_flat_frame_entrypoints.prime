import /std/math/*
import /std/gfx/*

[struct]
CubeMeshLayout() {
  [i32] vertexCount{8i32}
  [i32] indexCount{36i32}
  [i32] positionStrideBytes{16i32}
  [i32] colorStrideBytes{16i32}
  [i32] uniformStrideBytes{64i32}
}

[struct]
CubeSimulationState() {
  [i32] tick{0i32}
  [f32] angleRadians{0.0f32}
  [f32] angularVelocity{1.0471976f32}
  [f32] axisX{1.0f32}
  [f32] axisY{0.0f32}
  [CubeMeshLayout] mesh{CubeMeshLayout()}
}

[struct]
CubeStepResult() {
  [CubeSimulationState] state{CubeSimulationState()}
  [f32] remainingSeconds{0.0f32}
  [i32] stepCount{0i32}
}

[return<CubeMeshLayout>]
cubeMeshLayoutV1() {
  return(CubeMeshLayout())
}

[return<CubeSimulationState>]
cubeInit() {
  return(CubeSimulationState(
    [tick] 0i32,
    [angleRadians] 0.0f32,
    [angularVelocity] 1.0471976f32,
    [axisX] 1.0f32,
    [axisY] 0.0f32,
    [mesh] cubeMeshLayoutV1()
  ))
}

[return<f32>]
wrapAngle([f32] angle) {
  [f32 mut] wrapped{angle}
  [f32] tau{6.2831853f32}
  while(greater_equal(wrapped, tau)) {
    wrapped = minus(wrapped, tau)
  }
  while(less_than(wrapped, 0.0f32)) {
    wrapped = plus(wrapped, tau)
  }
  return(wrapped)
}

[return<CubeSimulationState>]
cubeTick([CubeSimulationState] state, [f32] deltaSeconds) {
  [i32] nextTick{plus(state.tick, 1i32)}
  [f32] nextAngle{wrapAngle(plus(state.angleRadians, multiply(state.angularVelocity, deltaSeconds)))}

  [f32] nextAxisX{plus(multiply(state.axisX, 0.9998477f32), multiply(state.axisY, -0.0174524f32))}
  [f32] nextAxisY{plus(multiply(state.axisX, 0.0174524f32), multiply(state.axisY, 0.9998477f32))}

  return(CubeSimulationState(
    [tick] nextTick,
    [angleRadians] nextAngle,
    [angularVelocity] state.angularVelocity,
    [axisX] nextAxisX,
    [axisY] nextAxisY,
    [mesh] state.mesh
  ))
}

[return<CubeStepResult>]
cubeAdvanceFixed([CubeSimulationState] state,
                 [f32] accumulatedSeconds,
                 [f32] fixedDeltaSeconds,
                 [i32] maxSteps) {
  [CubeSimulationState mut] current{state}
  [f32 mut] remaining{accumulatedSeconds}
  [i32 mut] steps{0i32}

  if(less_equal(fixedDeltaSeconds, 0.0f32)) {
    return(CubeStepResult(
      [state] current,
      [remainingSeconds] remaining,
      [stepCount] steps
    ))
  }

  if(less_than(maxSteps, 1i32)) {
    return(CubeStepResult(
      [state] current,
      [remainingSeconds] remaining,
      [stepCount] steps
    ))
  }

  while(greater_equal(remaining, fixedDeltaSeconds)) {
    if(greater_equal(steps, maxSteps)) {
      return(CubeStepResult(
        [state] current,
        [remainingSeconds] remaining,
        [stepCount] steps
      ))
    }

    current = cubeTick(current, fixedDeltaSeconds)
    remaining = minus(remaining, fixedDeltaSeconds)
    steps = plus(steps, 1i32)
  }

  return(CubeStepResult(
    [state] current,
    [remainingSeconds] remaining,
    [stepCount] steps
  ))
}

[return<CubeSimulationState>]
cubeRunFixedTicks([i32] ticks) {
  [CubeSimulationState mut] state{cubeInit()}
  [f32] fixedDelta{0.016666667f32}
  [i32 mut] i{0i32}

  while(less_than(i, ticks)) {
    [CubeStepResult] step{cubeAdvanceFixed(state, fixedDelta, fixedDelta, 1i32)}
    state = step.state
    i = plus(i, 1i32)
  }

  return(state)
}

[return<CubeSimulationState>]
cubeRunFixedTicksChunked([i32] ticks) {
  [CubeSimulationState mut] state{cubeInit()}
  [f32] fixedDelta{0.016666667f32}
  [f32 mut] accumulator{0.0f32}
  [i32 mut] i{0i32}

  while(less_than(i, ticks)) {
    accumulator = plus(accumulator, 0.010000000f32)
    [CubeStepResult] stepA{cubeAdvanceFixed(state, accumulator, fixedDelta, 4i32)}
    state = stepA.state
    accumulator = stepA.remainingSeconds

    accumulator = plus(accumulator, 0.006666667f32)
    [CubeStepResult] stepB{cubeAdvanceFixed(state, accumulator, fixedDelta, 4i32)}
    state = stepB.state
    accumulator = stepB.remainingSeconds

    i = plus(i, 1i32)
  }

  return(state)
}

[return<int>]
cubeFixedStepSnapshotCode([CubeSimulationState] state) {
  [i32] tickBucket{convert<int>(multiply(convert<f32>(state.tick), 0.1f32))}
  [i32] angleDeci{convert<int>(multiply(state.angleRadians, 10.0f32))}
  [i32] axisXShiftedDeci{convert<int>(multiply(plus(state.axisX, 1.0f32), 10.0f32))}
  [i32] axisYDeci{convert<int>(multiply(state.axisY, 10.0f32))}
  return(plus(plus(tickBucket, angleDeci), plus(axisXShiftedDeci, axisYDeci)))
}

[return<int>]
cubeFixedStepSnapshot120() {
  return(cubeFixedStepSnapshotCode(cubeRunFixedTicks(120i32)))
}

[return<int>]
cubeFixedStepSnapshot120Chunked() {
  return(cubeFixedStepSnapshotCode(cubeRunFixedTicksChunked(120i32)))
}

[return<int>]
cubeRotationParity120() {
  [CubeSimulationState] fixed{cubeRunFixedTicks(120i32)}
  [CubeSimulationState] chunked{cubeRunFixedTicksChunked(120i32)}
  [f32] angleDiff{abs(minus(fixed.angleRadians, chunked.angleRadians))}
  [f32] axisXDiff{abs(minus(fixed.axisX, chunked.axisX))}
  [f32] axisYDiff{abs(minus(fixed.axisY, chunked.axisY))}
  if(and(less_equal(angleDiff, 0.020000000f32),
         and(less_equal(axisXDiff, 0.020000000f32),
             less_equal(axisYDiff, 0.020000000f32)))) {
    return(1i32)
  } else {
    return(0i32)
  }
}

[return<int>]
cubeNativeMeshVertexCount() {
  return(8i32)
}

[return<int>]
cubeNativeMeshIndexCount() {
  return(36i32)
}

[return<int>]
cubeNativeFrameInitTick() {
  return(0i32)
}

[return<int>]
cubeNativeFrameInitAngleMilli() {
  return(0i32)
}

[return<int>]
cubeNativeFrameInitAxisXCenti() {
  return(100i32)
}

[return<int>]
cubeNativeFrameInitAxisYCenti() {
  return(0i32)
}

[return<int>]
cubeNativeFrameAngularVelocityMilli() {
  return(1047i32)
}

[return<int>]
cubeNativeFrameStepTick([i32] tick) {
  return(plus(tick, 1i32))
}

[return<int>]
cubeNativeFrameStepAngleMilli([i32] angleMilli, [i32] deltaMillis, [i32] angularVelocityMilli) {
  [f32] angle{divide(convert<f32>(angleMilli), 1000.0f32)}
  [f32] deltaSeconds{divide(convert<f32>(deltaMillis), 1000.0f32)}
  [f32] angularVelocity{divide(convert<f32>(angularVelocityMilli), 1000.0f32)}
  [f32] nextAngle{wrapAngle(plus(angle, multiply(angularVelocity, deltaSeconds)))}
  return(convert<int>(multiply(nextAngle, 1000.0f32)))
}

[return<int>]
cubeNativeFrameStepAxisXCenti([i32] axisXCenti, [i32] axisYCenti) {
  [f32] axisX{divide(convert<f32>(axisXCenti), 100.0f32)}
  [f32] axisY{divide(convert<f32>(axisYCenti), 100.0f32)}
  [f32] nextAxisX{plus(multiply(axisX, 0.9998477f32), multiply(axisY, -0.0174524f32))}
  return(convert<int>(multiply(nextAxisX, 100.0f32)))
}

[return<int>]
cubeNativeFrameStepAxisYCenti([i32] axisXCenti, [i32] axisYCenti) {
  [f32] axisX{divide(convert<f32>(axisXCenti), 100.0f32)}
  [f32] axisY{divide(convert<f32>(axisYCenti), 100.0f32)}
  [f32] nextAxisY{plus(multiply(axisX, 0.0174524f32), multiply(axisY, 0.9998477f32))}
  return(convert<int>(multiply(nextAxisY, 100.0f32)))
}

[return<int>]
cubeNativeFrameStepSnapshotCode() {
  [i32] initTick{cubeNativeFrameInitTick()}
  [i32] initAngleMilli{cubeNativeFrameInitAngleMilli()}
  [i32] initAxisXCenti{cubeNativeFrameInitAxisXCenti()}
  [i32] initAxisYCenti{cubeNativeFrameInitAxisYCenti()}
  [i32] angularVelocityMilli{cubeNativeFrameAngularVelocityMilli()}

  [i32] nextTick{cubeNativeFrameStepTick(initTick)}
  [i32] nextAngleMilli{cubeNativeFrameStepAngleMilli(initAngleMilli, 16i32, angularVelocityMilli)}
  [i32] nextAxisXCenti{cubeNativeFrameStepAxisXCenti(initAxisXCenti, initAxisYCenti)}
  [i32] nextAxisYCenti{cubeNativeFrameStepAxisYCenti(initAxisXCenti, initAxisYCenti)}

  return(plus(plus(nextTick, nextAngleMilli), plus(nextAxisXCenti, nextAxisYCenti)))
}

[effects(io_err)]
log_gfx_error([GfxError] err) {
  print_line_error(GfxError.why(err))
}

[return<int> effects(io_out, io_err) on_error<GfxError, /log_gfx_error>]
cubeStdGfxEmitFrameStream() {
  [Window] window{
    Window(
      [title] "PrimeStruct Stdlib Gfx"utf8,
      [width] 1280i32,
      [height] 720i32
    )?
  }
  [Device] device{Device()?}
  [Queue] queue{device.default_queue()}
  [Swapchain] swapchain{
    device.create_swapchain(
      window,
      [color_format] ColorFormat.Bgra8Unorm,
      [depth_format] DepthFormat.Depth32F,
      [present_mode] PresentMode.Fifo
    )?
  }
  [array<VertexColored>] vertices{
    array<VertexColored>(
      VertexColored([px] -0.6f32, [py] -0.6f32, [pz] -0.6f32, [pw] 1.0f32, [r] 1.0f32, [g] 0.2f32, [b] 0.2f32, [a] 1.0f32),
      VertexColored([px]  0.6f32, [py] -0.6f32, [pz] -0.6f32, [pw] 1.0f32, [r] 0.2f32, [g] 1.0f32, [b] 0.2f32, [a] 1.0f32),
      VertexColored([px]  0.6f32, [py]  0.6f32, [pz] -0.6f32, [pw] 1.0f32, [r] 0.2f32, [g] 0.2f32, [b] 1.0f32, [a] 1.0f32),
      VertexColored([px] -0.6f32, [py]  0.6f32, [pz] -0.6f32, [pw] 1.0f32, [r] 1.0f32, [g] 1.0f32, [b] 0.2f32, [a] 1.0f32),
      VertexColored([px] -0.6f32, [py] -0.6f32, [pz]  0.6f32, [pw] 1.0f32, [r] 1.0f32, [g] 0.2f32, [b] 1.0f32, [a] 1.0f32),
      VertexColored([px]  0.6f32, [py] -0.6f32, [pz]  0.6f32, [pw] 1.0f32, [r] 0.2f32, [g] 1.0f32, [b] 1.0f32, [a] 1.0f32),
      VertexColored([px]  0.6f32, [py]  0.6f32, [pz]  0.6f32, [pw] 1.0f32, [r] 1.0f32, [g] 0.6f32, [b] 0.2f32, [a] 1.0f32),
      VertexColored([px] -0.6f32, [py]  0.6f32, [pz]  0.6f32, [pw] 1.0f32, [r] 0.7f32, [g] 0.7f32, [b] 0.7f32, [a] 1.0f32)
    )
  }
  [array<i32>] indices{
    array<i32>(
      4i32, 5i32, 6i32, 4i32, 6i32, 7i32,
      0i32, 2i32, 1i32, 0i32, 3i32, 2i32,
      0i32, 4i32, 7i32, 0i32, 7i32, 3i32,
      1i32, 2i32, 6i32, 1i32, 6i32, 5i32,
      3i32, 7i32, 6i32, 3i32, 6i32, 2i32,
      0i32, 1i32, 5i32, 0i32, 5i32, 4i32
    )
  }
  [Mesh] mesh{device.create_mesh([vertices] vertices, [indices] indices)?}
  [Pipeline] pipeline{
    device.create_pipeline(
      [shader] ShaderLibrary.CubeBasic,
      [vertex_type] VertexColored,
      [color_format] ColorFormat.Bgra8Unorm,
      [depth_format] DepthFormat.Depth32F
    )?
  }
  [Material] material{pipeline.material()?}
  [ColorRGBA] clearColor{ColorRGBA(0.05f32, 0.07f32, 0.10f32, 1.0f32)}
  [f32] clearDepth{1.0f32}
  [i32] fixedDeltaMillis{16i32}
  [i32] angularVelocityMilli{cubeNativeFrameAngularVelocityMilli()}
  [i32 mut] tick{cubeNativeFrameInitTick()}
  [i32 mut] angleMilli{cubeNativeFrameInitAngleMilli()}
  [i32 mut] axisXCenti{cubeNativeFrameInitAxisXCenti()}
  [i32 mut] axisYCenti{cubeNativeFrameInitAxisYCenti()}
  [i32 mut] frameIndex{0i32}
  [i32] frameCount{600i32}

  while(less_than(frameIndex, frameCount)) {
    if(less_than(swapchain.token, 1i32)) {
      log_gfx_error(frameAcquireFailed())
      return(7i32)
    }
    [Frame] frame{Frame([token] plus(swapchain.token, 1i32))}
    [RenderPass] pass{
      frame.render_pass(
        [clear_color] clearColor,
        [clear_depth] clearDepth
      )
    }
    pass.draw_mesh(mesh, material)
    pass.end()
    [Result<GfxError>] submitStatus{frame.submit(queue)}
    if(Result.error(submitStatus)) {
      log_gfx_error(queueSubmitFailed())
      return(8i32)
    }
    [Result<GfxError>] presentStatus{frame.present()}
    if(Result.error(presentStatus)) {
      log_gfx_error(framePresentFailed())
      return(9i32)
    }

    if(equal(frameIndex, 0i32)) {
      print_line(17001i32)
      print_line(1i32)
      print_line(window.width)
      print_line(window.height)
      print_line(swapchain.colorFormat.value)
      print_line(swapchain.depthFormat.value)
      print_line(swapchain.presentMode.value)
      print_line(convert<int>(multiply(clearColor.r, 1000.0f32)))
      print_line(convert<int>(multiply(clearColor.g, 1000.0f32)))
      print_line(convert<int>(multiply(clearColor.b, 1000.0f32)))
      print_line(convert<int>(multiply(clearColor.a, 1000.0f32)))
      print_line(convert<int>(multiply(clearDepth, 1000.0f32)))
      print_line(mesh.vertexCount)
      print_line(mesh.indexCount)
      print_line(window.token)
      print_line(device.token)
      print_line(queue.token)
      print_line(swapchain.token)
      print_line(mesh.token)
      print_line(pipeline.token)
      print_line(material.token)
      print_line(frame.token)
      print_line(pass.token)
      print_line(plus(pass.token, plus(mesh.token, material.token)))
      print_line(plus(pass.token, 1i32))
      print_line(3i32)
    }

    print_line(tick)
    print_line(angleMilli)
    print_line(axisXCenti)
    print_line(axisYCenti)

    [i32] nextTick{cubeNativeFrameStepTick(tick)}
    [i32] nextAngleMilli{cubeNativeFrameStepAngleMilli(angleMilli, fixedDeltaMillis, angularVelocityMilli)}
    [i32] nextAxisXCenti{cubeNativeFrameStepAxisXCenti(axisXCenti, axisYCenti)}
    [i32] nextAxisYCenti{cubeNativeFrameStepAxisYCenti(axisXCenti, axisYCenti)}

    tick = nextTick
    angleMilli = nextAngleMilli
    axisXCenti = nextAxisXCenti
    axisYCenti = nextAxisYCenti
    frameIndex = plus(frameIndex, 1i32)
  }

  return(0i32)
}

[return<int>]
mainNative() {
  return(cubeNativeMeshIndexCount())
}

[return<int>]
main() {
  [CubeSimulationState] state0{cubeInit()}
  [CubeSimulationState] state1{cubeTick(state0, 0.016666667f32)}
  [CubeMeshLayout] mesh{state1.mesh}
  if(greater_than(state1.angleRadians, state0.angleRadians)) {
    return(mesh.indexCount)
  } else {
    return(0i32)
  }
}


[return<int>]
cubeNativeFlatFrameDeterminismSmoke() {
  if(not_equal(cubeNativeMeshVertexCount(), 8i32)) {
    return(11i32)
  } else {
  }
  if(not_equal(cubeNativeMeshIndexCount(), 36i32)) {
    return(12i32)
  } else {
  }
  if(not_equal(cubeNativeFrameInitTick(), 0i32)) {
    return(13i32)
  } else {
  }
  if(not_equal(cubeNativeFrameInitAngleMilli(), 0i32)) {
    return(14i32)
  } else {
  }
  if(not_equal(cubeNativeFrameInitAxisXCenti(), 100i32)) {
    return(15i32)
  } else {
  }
  if(not_equal(cubeNativeFrameInitAxisYCenti(), 0i32)) {
    return(16i32)
  } else {
  }
  if(not_equal(cubeNativeFrameAngularVelocityMilli(), 1047i32)) {
    return(17i32)
  } else {
  }
  if(not_equal(cubeNativeFrameStepSnapshotCode(), 117i32)) {
    return(18i32)
  } else {
  }
  return(0i32)
}
