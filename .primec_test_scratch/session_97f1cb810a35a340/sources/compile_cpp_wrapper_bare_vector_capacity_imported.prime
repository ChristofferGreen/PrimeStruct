
import /std/collections/*

[effects(heap_alloc), return<vector<i32>>]
wrapVector() {
  return(vector<i32>(5i32, 6i32, 7i32))
}

[effects(heap_alloc), return<int>]
/std/collections/vector/capacity([vector<i32>] values) {
  return(17i32)
}

[effects(heap_alloc), return<int>]
main() {
  return(capacity(wrapVector()))
}
