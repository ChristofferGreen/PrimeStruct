import /std/collections/*

import /std/collections/experimental_vector/*

[struct]
Owned() {
  [i32 mut] value{0i32}

  Destroy() {
  }
}

[struct]
Wrapper() {
  [Owned] value{Owned()}
}

[effects(heap_alloc), return<int>]
main() {
  [Vector<Owned> mut] popped{/std/collections/vectorSingle<Owned>(Owned(3i32))}
  popped.pop()
  [Vector<Wrapper> mut] cleared{/std/collections/vectorPair<Wrapper>(Wrapper(Owned(4i32)), Wrapper(Owned(5i32)))}
  /std/collections/vector/clear<Wrapper>(cleared)
  return(plus(/std/collections/vector/count<Owned>(popped), /std/collections/vector/count<Wrapper>(cleared)))
}
