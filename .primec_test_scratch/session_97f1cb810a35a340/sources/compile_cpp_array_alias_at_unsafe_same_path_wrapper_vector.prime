
[return<int>]
/array/at_unsafe([vector<i32>] values, [i32] index, [bool] marker) {
  return(50i32)
}

[effects(heap_alloc), return<vector<i32>>]
wrapVector() {
  return(vector<i32>(5i32, 6i32, 7i32))
}

[effects(heap_alloc), return<int>]
main() {
  return(/array/at_unsafe(wrapVector(), 1i32, true))
}
