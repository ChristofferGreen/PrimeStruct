
[return<int>]
main() {
  [i32 mut] result{0i32}
  [shared_scope]
  loop(4i32) {
    [i32 mut] total{0i32}
    assign(total, plus(total, 1i32))
    assign(result, total)
  }
  [shared_scope]
  for([i32 mut] i{1i32} less_than(i 10i32) assign(i, multiply(i, 2i32))) {
    [i32 mut] total{i}
    assign(total, plus(total, 1i32))
    assign(result, total)
  }
  return(result)
}
