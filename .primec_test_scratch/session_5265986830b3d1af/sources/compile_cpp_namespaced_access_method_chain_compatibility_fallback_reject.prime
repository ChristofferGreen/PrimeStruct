
namespace i32 {
  [return<int>]
  tag([i32] value) {
    return(plus(value, 1i32))
  }
}

[effects(heap_alloc), return<int>]
main() {
  [vector<i32>] values{vector<i32>(7i32, 8i32)}
  return(plus(/std/collections/vector/at(values, 0i32).tag(),
              /vector/at_unsafe(values, 1i32).tag()))
}
