
Marker {
  [i32] value
}

[return<Marker>]
/map/contains([map<i32, i32>] values, [i32] key) {
  return(Marker(19i32))
}

[return<int>]
/Marker/tag([Marker] self) {
  return(self.value)
}

[effects(heap_alloc), return<int>]
main() {
  [map<i32, i32>] values{map<i32, i32>(1i32, 4i32)}
  return(values.contains(1i32).tag())
}
