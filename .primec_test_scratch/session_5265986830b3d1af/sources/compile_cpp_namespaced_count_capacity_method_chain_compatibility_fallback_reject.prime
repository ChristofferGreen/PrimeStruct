
namespace i32 {
  [return<int>]
  tag([i32] value) {
    return(plus(value, 1i32))
  }
}

[effects(heap_alloc), return<int>]
main() {
  [string] text{"abc"raw_utf8}
  [vector<i32>] values{vector<i32>(1i32, 2i32)}
  return(plus(/std/collections/vector/count(text).tag(),
              /vector/capacity(values).tag()))
}
