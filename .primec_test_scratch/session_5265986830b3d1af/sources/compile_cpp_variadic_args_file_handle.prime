main() {
  [File<Write>] a0{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_a0.txt"utf8)?}
  [File<Write>] a1{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_a1.txt"utf8)?}
  [File<Write>] a2{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_a2.txt"utf8)?}
  [File<Write>] b0{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_b0.txt"utf8)?}
  [File<Write>] b1{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_b1.txt"utf8)?}
  [File<Write>] b2{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_b2.txt"utf8)?}
  [File<Write>] c0{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_c0.txt"utf8)?}
  [File<Write>] c1{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_file_handle_c1.txt"utf8)?}
