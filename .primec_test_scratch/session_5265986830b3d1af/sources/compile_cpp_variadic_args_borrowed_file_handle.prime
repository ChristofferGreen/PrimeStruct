  [Reference<File<Write>>] r0{location(a0)}
  [Reference<File<Write>>] r1{location(a1)}
  [Reference<File<Write>>] r2{location(a2)}
  [File<Write>] b0{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_borrowed_file_handle_b0.txt"utf8)?}
  [File<Write>] b1{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_borrowed_file_handle_b1.txt"utf8)?}
  [File<Write>] b2{File<Write>("/Users/chrgre01/src/PrimeStruct/.primec_test_scratch/session_5265986830b3d1af/primec_cpp_variadic_borrowed_file_handle_b2.txt"utf8)?}
  [Reference<File<Write>>] s0{location(b0)}
